@inject ApiSession Session

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Mini ERP</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">لوحة التحكم</NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">المنتجات</NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="inventory">المخزون</NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pos">فاتورة</NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="returns">مرتجع</NavLink>
        </div>

        <div class="nav-item px-3">
            @if (!Session.IsLoggedIn)
            {
                <NavLink class="nav-link" href="login">تسجيل الدخول</NavLink>
            }
            else
            {
                <NavLink class="nav-link" href="logout">خروج</NavLink>
            }
        </div>
    </nav>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync();
        StateHasChanged();
    }
}

