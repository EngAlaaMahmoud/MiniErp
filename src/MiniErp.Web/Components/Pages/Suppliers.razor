@page "/suppliers"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations

<PageTitle>@L["Suppliers.Title"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Suppliers.Title"]</h1>
        <a class="btn btn-outline-secondary" href="/">@L["Common.Back"]</a>
    </div>

    @if (!_ready)
    {
        <div class="text-muted">@L["Common.Loading"]</div>
    }
    else if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="alert alert-success">@_success</div>
        }

        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex gap-2 mb-2">
                            <input class="form-control" placeholder="@L["Suppliers.Search"]" @bind="_search" @bind:event="oninput" />
                            <button class="btn btn-outline-primary" @onclick="Load" disabled="@_busy">@L["Common.Refresh"]</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>@L["Suppliers.Name"]</th>
                                        <th>@L["Suppliers.TaxRegistrationNo"]</th>
                                        <th>@L["Suppliers.Phone"]</th>
                                        <th>@L["Common.Active"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in _suppliers)
                                    {
                                        <tr>
                                            <td>@s.Name</td>
                                            <td class="text-muted">@((string.IsNullOrWhiteSpace(s.TaxRegistrationNo) ? "-" : s.TaxRegistrationNo))</td>
                                            <td class="text-muted">@((string.IsNullOrWhiteSpace(s.Phone) ? "-" : s.Phone))</td>
                                            <td>@(s.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectForEdit(s)">@L["Common.Edit"]</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Suppliers.Add"]</div>
                        <EditForm Model="_create" OnValidSubmit="Create">
                            <DataAnnotationsValidator />
                            <div class="mb-2">
                                <label class="form-label">@L["Suppliers.Name"]</label>
                                <InputText class="form-control" @bind-Value="_create.Name" />
                                <ValidationMessage For="@(() => _create.Name)" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">@L["Suppliers.TaxRegistrationNo"]</label>
                                <InputText class="form-control" @bind-Value="_create.TaxRegistrationNo" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">@L["Suppliers.PhoneOptional"]</label>
                                <InputText class="form-control" @bind-Value="_create.Phone" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">@L["Suppliers.Address"]</label>
                                <div class="row g-2">
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.Country"]</label>
                                        <InputText class="form-control" @bind-Value="_create.Country" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.Governorate"]</label>
                                        <InputText class="form-control" @bind-Value="_create.Governorate" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.City"]</label>
                                        <InputText class="form-control" @bind-Value="_create.City" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.BuildingNo"]</label>
                                        <InputText class="form-control" @bind-Value="_create.BuildingNo" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.Floor"]</label>
                                        <InputText class="form-control" @bind-Value="_create.Floor" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.Apartment"]</label>
                                        <InputText class="form-control" @bind-Value="_create.Apartment" />
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <label class="form-label small text-muted">@L["Suppliers.StreetName"]</label>
                                        <InputText class="form-control" @bind-Value="_create.StreetName" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label small text-muted">@L["Suppliers.PostalCodeOptional"]</label>
                                        <InputText class="form-control" @bind-Value="_create.PostalCode" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-check mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_create.IsActive" />
                                <label class="form-check-label">@L["Common.Active"]</label>
                            </div>
                            <button class="btn btn-primary w-100" type="submit" disabled="@_busy">@L["Common.Save"]</button>
                        </EditForm>
                    </div>
                </div>

                @if (_edit is not null)
                {
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-bold">@L["Suppliers.Edit"]</div>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearEdit" disabled="@_busy">@L["Common.Cancel"]</button>
                            </div>
                            <EditForm Model="_edit" OnValidSubmit="Update">
                                <DataAnnotationsValidator />
                                <div class="mb-2">
                                    <label class="form-label">@L["Suppliers.Name"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Name" />
                                    <ValidationMessage For="@(() => _edit.Name)" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">@L["Suppliers.TaxRegistrationNo"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.TaxRegistrationNo" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">@L["Suppliers.PhoneOptional"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Phone" />
                                </div>

                                <div class="mb-2">
                                    <label class="form-label">@L["Suppliers.Address"]</label>
                                    <div class="row g-2">
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.Country"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.Country" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.Governorate"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.Governorate" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.City"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.City" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.BuildingNo"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.BuildingNo" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.Floor"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.Floor" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.Apartment"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.Apartment" />
                                        </div>
                                        <div class="col-12 col-md-8">
                                            <label class="form-label small text-muted">@L["Suppliers.StreetName"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.StreetName" />
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label class="form-label small text-muted">@L["Suppliers.PostalCodeOptional"]</label>
                                            <InputText class="form-control" @bind-Value="_edit.PostalCode" />
                                        </div>
                                    </div>
                                </div>

                                <div class="form-check mb-3">
                                    <InputCheckbox class="form-check-input" @bind-Value="_edit.IsActive" />
                                    <label class="form-check-label">@L["Common.Active"]</label>
                                </div>
                                <button class="btn btn-success w-100" type="submit" disabled="@_busy">@L["Common.Save"]</button>
                            </EditForm>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _success;
    private string _search = "";

    private List<SupplierListItem> _suppliers = [];
    private CreateSupplierModel _create = new();
    private UpdateSupplierModel? _edit;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync();
        _ready = true;
        if (Session.IsLoggedIn)
        {
            await Load();
        }
        StateHasChanged();
    }

    private async Task Load()
    {
        _error = null;
        _success = null;
        _busy = true;
        try
        {
            var q = string.IsNullOrWhiteSpace(_search) ? "" : $"?search={Uri.EscapeDataString(_search.Trim())}";
            _suppliers = await Api.GetAsync<List<SupplierListItem>>($"suppliers{q}");
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Create()
    {
        _error = null;
        _success = null;
        _busy = true;
        try
        {
            var response = await Api.PostAsync("suppliers", new
            {
                name = _create.Name.Trim(),
                phone = NullIfEmpty(_create.Phone),
                taxRegistrationNo = NullIfEmpty(_create.TaxRegistrationNo),
                country = NullIfEmpty(_create.Country),
                governorate = NullIfEmpty(_create.Governorate),
                city = NullIfEmpty(_create.City),
                buildingNo = NullIfEmpty(_create.BuildingNo),
                floor = NullIfEmpty(_create.Floor),
                apartment = NullIfEmpty(_create.Apartment),
                streetName = NullIfEmpty(_create.StreetName),
                postalCode = NullIfEmpty(_create.PostalCode),
                isActive = _create.IsActive
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            _create = new CreateSupplierModel();
            _success = L["Common.Added"].Value;
            await Load();
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _busy = false;
        }
    }

    private void SelectForEdit(SupplierListItem item)
    {
        _edit = new UpdateSupplierModel
        {
            Id = item.Id,
            Name = item.Name,
            Phone = item.Phone ?? "",
            TaxRegistrationNo = item.TaxRegistrationNo ?? "",
            Country = item.Country ?? "",
            Governorate = item.Governorate ?? "",
            City = item.City ?? "",
            BuildingNo = item.BuildingNo ?? "",
            Floor = item.Floor ?? "",
            Apartment = item.Apartment ?? "",
            StreetName = item.StreetName ?? "",
            PostalCode = item.PostalCode ?? "",
            IsActive = item.IsActive
        };
    }

    private void ClearEdit() => _edit = null;

    private async Task Update()
    {
        if (_edit is null)
        {
            return;
        }

        _error = null;
        _success = null;
        _busy = true;
        try
        {
            var response = await Api.PutAsync($"suppliers/{_edit.Id}", new
            {
                name = _edit.Name.Trim(),
                phone = NullIfEmpty(_edit.Phone),
                taxRegistrationNo = NullIfEmpty(_edit.TaxRegistrationNo),
                country = NullIfEmpty(_edit.Country),
                governorate = NullIfEmpty(_edit.Governorate),
                city = NullIfEmpty(_edit.City),
                buildingNo = NullIfEmpty(_edit.BuildingNo),
                floor = NullIfEmpty(_edit.Floor),
                apartment = NullIfEmpty(_edit.Apartment),
                streetName = NullIfEmpty(_edit.StreetName),
                postalCode = NullIfEmpty(_edit.PostalCode),
                isActive = _edit.IsActive
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            _success = L["Common.Updated"].Value;
            _edit = null;
            await Load();
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _busy = false;
        }
    }

    private void RedirectToLogin()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/login" : $"/login?return=/{Uri.EscapeDataString(relative)}";
        Nav.NavigateTo(target);
    }

    private static string? NullIfEmpty(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class SupplierListItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? Phone { get; set; }
        public string? TaxRegistrationNo { get; set; }
        public string? Country { get; set; }
        public string? Governorate { get; set; }
        public string? City { get; set; }
        public string? BuildingNo { get; set; }
        public string? Floor { get; set; }
        public string? Apartment { get; set; }
        public string? StreetName { get; set; }
        public string? PostalCode { get; set; }
        public bool IsActive { get; set; }
    }

    private class CreateSupplierModel
    {
        [Required]
        [MaxLength(300)]
        public string Name { get; set; } = "";

        [MaxLength(50)]
        public string Phone { get; set; } = "";

        [MaxLength(50)]
        public string TaxRegistrationNo { get; set; } = "";

        [MaxLength(100)]
        public string Country { get; set; } = "مصر";

        [MaxLength(100)]
        public string Governorate { get; set; } = "";

        [MaxLength(100)]
        public string City { get; set; } = "";

        [MaxLength(50)]
        public string BuildingNo { get; set; } = "";

        [MaxLength(50)]
        public string Floor { get; set; } = "";

        [MaxLength(50)]
        public string Apartment { get; set; } = "";

        [MaxLength(200)]
        public string StreetName { get; set; } = "";

        [MaxLength(20)]
        public string PostalCode { get; set; } = "";

        public bool IsActive { get; set; } = true;
    }

    private sealed class UpdateSupplierModel : CreateSupplierModel
    {
        public Guid Id { get; set; }
    }
}

