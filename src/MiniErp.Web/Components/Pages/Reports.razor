        => type switch
        {
            1 => "SaleIn",
            2 => "RefundOut",
            3 => "ExpenseOut",
            4 => "DepositIn",
            5 => "WithdrawOut",
            _ => type.ToString()
        };

    private static string StockReasonLabel(int reason)
        => reason switch
        {
            1 => "Sale",
            2 => "Return",
            3 => "Adjustment",
            4 => "Purchase",
            _ => reason.ToString()
        };

