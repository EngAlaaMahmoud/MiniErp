@page "/unit-measures"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations

<PageTitle>@L["Nav.UnitMeasures"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Nav.UnitMeasures"]</h1>
        <a class="btn btn-outline-secondary" href="/">@L["Common.Back"]</a>
    </div>

    @if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else
    {
        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex gap-2 mb-2">
                            <button class="btn btn-outline-primary" @onclick="Load" disabled="@_busy">@L["Common.Refresh"]</button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="alert alert-danger">@_error</div>
                        }

                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>@L["Common.Name"]</th>
                                        <th>@L["Common.Active"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var u in _items)
                                    {
                                        <tr>
                                            <td>@u.Name</td>
                                            <td>@(u.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectForEdit(u)">@L["Common.Edit"]</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="fw-bold">@(_form.Id is null ? L["Common.Add"] : L["Common.Edit"])</div>
                            @if (_form.Id is not null)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearForm" disabled="@_busy">@L["Common.Cancel"]</button>
                            }
                        </div>

                        <EditForm Model="_form" OnValidSubmit="Save">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="mb-2">
                                <label class="form-label">@L["Common.Name"]</label>
                                <InputText class="form-control" @bind-Value="_form.Name" />
                            </div>
                            <div class="form-check mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                                <label class="form-check-label">@L["Common.Active"]</label>
                            </div>

                            <button class="btn btn-primary w-100" disabled="@_busy">@L["Common.Save"]</button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _busy;
    private string? _error;
    private List<UnitMeasureItem> _items = [];
    private UnitFormModel _form = new() { IsActive = true };
    private bool _initialLoadDone;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone)
        {
            return;
        }

        _initialLoadDone = true;
        await Session.EnsureLoadedAsync();
        if (Session.IsLoggedIn)
        {
            await Load();
        }

        StateHasChanged();
    }

    private async Task Load()
    {
        _busy = true;
        _error = null;
        try
        {
            _items = await Api.GetAsync<List<UnitMeasureItem>>("catalog/unit-measures");
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void SelectForEdit(UnitMeasureItem item)
    {
        _form = new UnitFormModel
        {
            Id = item.Id,
            Name = item.Name,
            IsActive = item.IsActive
        };
    }

    private void ClearForm()
    {
        _form = new UnitFormModel { IsActive = true };
        _error = null;
    }

    private async Task Save()
    {
        _busy = true;
        _error = null;
        try
        {
            HttpResponseMessage response;
            if (_form.Id is null)
            {
                response = await Api.PostAsync("catalog/unit-measures", new
                {
                    name = _form.Name,
                    isActive = _form.IsActive
                });
            }
            else
            {
                response = await Api.PutAsync($"catalog/unit-measures/{_form.Id}", new
                {
                    name = _form.Name,
                    isActive = _form.IsActive
                });
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            ClearForm();
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class UnitMeasureItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public bool IsActive { get; set; }
    }

    private sealed class UnitFormModel
    {
        public Guid? Id { get; set; }
        [Required] public string Name { get; set; } = "";
        public bool IsActive { get; set; }
    }

    private void RedirectToLogin()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/login" : $"/login?return=/{Uri.EscapeDataString(relative)}";
        Nav.NavigateTo(target);
    }
}
