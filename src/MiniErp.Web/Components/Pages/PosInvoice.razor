@page "/pos"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Web
@using Net.Codecrete.QrCodeGenerator
@using MiniErp.Web.Security
@using System.Net.Http.Json

<PageTitle>@L["Nav.Sales"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Nav.Sales"]</h1>
        <a class="btn btn-outline-secondary" href="/">@L["Nav.Dashboard"]</a>
    </div>

    @if (!_ready)
    {
        <div class="text-muted">@L["Common.Loading"]</div>
    }
    else if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else if (!Session.HasPermission(PermissionKeys.SalesCreate))
    {
        <div class="alert alert-danger">@L["Auth.Unauthorized"]</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="alert alert-success d-print-none">
                @_success
                @if (_receipt is not null)
                {
                    <div class="mt-2">
                        <button class="btn btn-sm btn-outline-dark" @onclick="Print" disabled="@_busy">@L["Common.Print"]</button>
                    </div>
                }
            </div>
        }

        <div class="row g-3 d-print-none">
            <div class="col-lg-8">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Sales.MainInfo"]</div>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label">@L["Sales.Number"]</label>
                                <input class="form-control" value="@(_receipt?.SaleNo ?? L["Sales.AutoSequenceHint"].Value)" readonly />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">@L["Sales.OrderDate"]</label>
                                <InputDate class="form-control" @bind-Value="_atDate" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">@L["Sales.PaymentMethod"]</label>
                                <select class="form-select" @bind="_paymentMethod" @bind:after="OnPaymentMethodChanged">
                                    <option value="Cash">@L["Payments.Cash"]</option>
                                    <option value="Visa">@L["Payments.Visa"]</option>
                                    <option value="Bank">@L["Payments.Bank"]</option>
                                    <option value="OnAccount">@L["Payments.OnAccount"]</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-md-6">
                                <label class="form-label">@L["Sales.CustomerOptional"]</label>
                                <select class="form-select" @bind="_customerId" @bind:after="OnCustomerChanged">
                                    <option value="">-</option>
                                    @foreach (var c in _customers.Where(x => x.IsActive))
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                                <div class="small text-muted mt-1">@L["Sales.CustomerNote"]</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@L["Sales.CustomerNameOptional"]</label>
                                <InputText class="form-control" @bind-Value="_customerName" />
                            </div>
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-md-6">
                                <label class="form-label">@L["Sales.CustomerTaxRegistrationOrNationalId"]</label>
                                <InputText class="form-control" @bind-Value="_customerTaxRegistrationNo" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@L["Sales.Withholding"]</label>
                                <input class="form-control" value="0.05 / w013 / T4" readonly />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Sales.Items"]</div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-muted small">@L["Sales.PriceIncludesVatHint"]</div>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadLookups" disabled="@_busy">@L["Common.Refresh"]</button>
                        </div>

                        <div class="row g-2 align-items-end mb-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["Sales.Product"]</label>
                                <select class="form-select" value="@_selectedProductId" @onchange="OnSelectedProductChanged" disabled="@_busy">
                                    <option value="">@L["Sales.Select"]</option>
                                    @foreach (var p in _products.Where(x => x.IsActive))
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">@L["Sales.Unit"]</label>
                                <select class="form-select" @bind="_selectedProductUnitId" disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedProductId) || _selectedUnits.Count == 0)">
                                    <option value="">-</option>
                                    @foreach (var u in _selectedUnits.Where(x => x.IsActive))
                                    {
                                        <option value="@u.Id">@u.Name (x@u.Factor)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-2">
                                <button class="btn btn-outline-primary w-100" @onclick="AddSelectedProduct" disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedProductId))">@L["Common.Add"]</button>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mb-3">
                            <input class="form-control" placeholder="@L["Sales.BarcodePlaceholder"]" @bind="_barcode" @bind:event="oninput" @onkeydown="OnBarcodeKeyDown" />
                            <button class="btn btn-outline-primary" @onclick="LookupAndAdd" disabled="@_busy">@L["Common.Add"]</button>
                            <button class="btn btn-outline-secondary" @onclick="ClearLines" disabled="@_busy">@L["Common.Cancel"]</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th class="text-end">@L["Sales.Col.Total"]</th>
                                        <th class="text-end">@L["Sales.Col.Vat"]</th>
                                        <th class="text-end">@L["Sales.Col.TotalBeforeVat"]</th>
                                        <th class="text-end">@L["Sales.Col.TableTax"]</th>
                                        <th class="text-end">@L["Sales.Col.ServiceFee"]</th>
                                        <th class="text-end">@L["Sales.Col.AdditionalTaxes"]</th>
                                        <th class="text-end">@L["Sales.Col.AdditionalFees"]</th>
                                        <th class="text-end">@L["Sales.Col.Discount"]</th>
                                        <th class="text-end">@L["Sales.Col.Qty"]</th>
                                        <th class="text-end">@L["Sales.Col.UnitPrice"]</th>
                                        <th>@L["Sales.Col.InternalCode"]</th>
                                        <th>@L["Sales.Col.EgsCode"]</th>
                                        <th>@L["Sales.Col.Product"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < _lines.Count; i++)
                                    {
                                        var line = _lines[i];
                                        var total = LineTotal(line);
                                        var vat = IncludedVat(total, line.TaxPercent);
                                        var beforeVat = total - vat;
                                        <tr>
                                            <td class="text-end">@total</td>
                                            <td class="text-end">@vat</td>
                                            <td class="text-end">@beforeVat</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end" style="width:120px">
                                                <input class="form-control form-control-sm text-end" type="number" step="0.001" @bind-value="line.Discount" @bind-value:event="oninput" disabled="@_busy" />
                                            </td>
                                            <td class="text-end" style="width:120px">
                                                <input class="form-control form-control-sm text-end" type="number" step="0.001" @bind-value="line.Qty" @bind-value:event="oninput" disabled="@_busy" />
                                            </td>
                                            <td class="text-end" style="width:140px">
                                                <input class="form-control form-control-sm text-end" type="number" step="0.001" @bind-value="line.UnitPrice" @bind-value:event="oninput" disabled="@_busy" />
                                            </td>
                                            <td class="text-muted">@line.Sku</td>
                                            <td class="text-muted">@line.PrimaryBarcode</td>
                                            <td>
                                                @line.Name
                                                @if (!string.IsNullOrWhiteSpace(line.UnitName))
                                                {
                                                    <span class="text-muted small">(@line.UnitName)</span>
                                                }
                                            </td>
                                            <td class="text-end" style="width:70px">
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(i)" disabled="@_busy">x</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th class="text-end">@GrandTotal</th>
                                        <th class="text-end">@GrandVat</th>
                                        <th class="text-end">@GrandBeforeVat</th>
                                        <th colspan="10"></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-md-8">
                                <label class="form-label">@L["Common.Note"] (@L["Common.Optional"])</label>
                                <InputText class="form-control" @bind-Value="_note" />
                            </div>
                            <div class="col-md-4">
                                @if (_paymentMethod == "Cash")
                                {
                                    <label class="form-label">@L["Sales.CashTendered"]</label>
                                    <InputNumber class="form-control text-end" @bind-Value="_cashTendered" />
                                    <div class="small text-muted mt-1">@L["Sales.Change"]: <strong>@Change</strong></div>
                                }
                                else if (_paymentMethod == "Visa" || _paymentMethod == "Bank")
                                {
                                    <label class="form-label">@L["Sales.ReferenceOptional"]</label>
                                    <InputText class="form-control" @bind-Value="_referenceNo" />
                                }
                            </div>
                        </div>

                        <button class="btn btn-success w-100 mt-3" @onclick="SaveSale" disabled="@(_busy || _lines.Count == 0)">@L["Sales.SaveAndPay"]</button>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Sales.Summary"]</div>
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <th>@L["Sales.TotalBeforeVat"]</th>
                                    <td class="text-end">@GrandBeforeVat</td>
                                </tr>
                                <tr>
                                    <th>@L["Sales.Vat"]</th>
                                    <td class="text-end">@GrandVat</td>
                                </tr>
                                <tr>
                                    <th>@L["Sales.InvoiceDiscount"]</th>
                                    <td class="text-end" style="width: 160px;">
                                        <InputNumber class="form-control form-control-sm text-end" @bind-Value="_invoiceDiscount" />
                                    </td>
                                </tr>
                                <tr>
                                    <th>@L["Common.Total"]</th>
                                    <td class="text-end fw-bold">@GrandTotal</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @if (_receipt is not null)
        {
            <div class="d-none d-print-block">
                <div style="max-width: 520px; margin: 0 auto;">
                    <h2 class="h5 text-center mb-3">@L["Sales.PrintTitle"]</h2>
                    <div class="small text-muted mb-1">@L["Sales.Number"]: <strong>@_receipt.SaleNo</strong></div>
                    <div class="small text-muted mb-1">@L["Common.Date"]: @_receipt.At.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="small text-muted mb-1">@L["Sales.CustomerOptional"]: @(string.IsNullOrWhiteSpace(_receipt.CustomerName) ? "-" : _receipt.CustomerName)</div>
                    <div class="small text-muted mb-2">@L["Sales.CustomerTaxRegistrationOrNationalId"]: @(string.IsNullOrWhiteSpace(_receipt.CustomerTaxRegistrationNo) ? "-" : _receipt.CustomerTaxRegistrationNo)</div>

                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>@L["Sales.Col.Product"]</th>
                                <th class="text-end">@L["Sales.Col.Qty"]</th>
                                <th class="text-end">@L["Sales.Col.UnitPrice"]</th>
                                <th class="text-end">@L["Sales.Col.Discount"]</th>
                                <th class="text-end">@L["Common.Total"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _receipt.Lines)
                            {
                                <tr>
                                    <td>@line.ProductName</td>
                                    <td class="text-end">@line.Qty</td>
                                    <td class="text-end">@line.UnitPrice</td>
                                    <td class="text-end">@line.Discount</td>
                                    <td class="text-end">@line.LineTotal</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">@L["Sales.TotalBeforeVat"]</th>
                                <th class="text-end">@_receipt.TotalBeforeVat</th>
                            </tr>
                            <tr>
                                <th colspan="4" class="text-end">@L["Sales.Vat"]</th>
                                <th class="text-end">@_receipt.TaxTotal</th>
                            </tr>
                            <tr>
                                <th colspan="4" class="text-end">@L["Sales.InvoiceDiscount"]</th>
                                <th class="text-end">@_lastInvoiceDiscount</th>
                            </tr>
                            <tr>
                                <th colspan="4" class="text-end">@L["Common.Total"]</th>
                                <th class="text-end fw-bold">@_receipt.Total</th>
                            </tr>
                        </tfoot>
                    </table>

                    @if (!string.IsNullOrWhiteSpace(_qrSvg))
                    {
                        <div class="mt-3 text-center">
                            @((MarkupString)_qrSvg)
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _success;

    private DateTime _atDate = DateTime.Today;
    private string _paymentMethod = "Cash";
    private decimal _cashTendered;
    private string? _referenceNo;
    private string? _note;
    private decimal _invoiceDiscount;
    private decimal _lastInvoiceDiscount;
    private string? _saleIdempotencyKey;

    private string _customerId = "";
    private string? _customerName;
    private string? _customerTaxRegistrationNo;

    private string _barcode = "";

    private List<ProductOption> _products = [];
    private List<CustomerOption> _customers = [];
    private readonly Dictionary<Guid, List<UnitOption>> _unitsByProductId = [];
    private readonly Dictionary<Guid, decimal> _taxPercentByRateId = [];

    private string _selectedProductId = "";
    private string _selectedProductUnitId = "";
    private List<UnitOption> _selectedUnits = [];

    private readonly List<CartLine> _lines = [];
    private SaleReceipt? _receipt;
    private string? _qrSvg;

    private decimal GrandTotal => ComputeTotals(_invoiceDiscount).Total;
    private decimal GrandVat => ComputeTotals(_invoiceDiscount).Vat;
    private decimal GrandBeforeVat => ComputeTotals(_invoiceDiscount).BeforeVat;
    private decimal Change => _paymentMethod == "Cash" && _cashTendered > GrandTotal ? decimal.Round(_cashTendered - GrandTotal, 3, MidpointRounding.AwayFromZero) : 0m;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync();
        _ready = true;

        if (Session.IsLoggedIn && Session.HasPermission(PermissionKeys.SalesCreate))
        {
            await ReloadLookups();
        }

        StateHasChanged();
    }

    private async Task ReloadLookups()
    {
        _error = null;
        _busy = true;
        try
        {
            _products = await Api.GetAsync<List<ProductOption>>("catalog/products");
            _customers = await Api.GetAsync<List<CustomerOption>>("customers");
            var rates = await Api.GetAsync<List<TaxRateOption>>("taxes/rates");

            _taxPercentByRateId.Clear();
            foreach (var r in rates)
            {
                _taxPercentByRateId[r.Id] = r.Percent;
            }
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnPaymentMethodChanged()
    {
        _cashTendered = _paymentMethod == "Cash" ? GrandTotal : 0;
    }

    private void OnCustomerChanged()
    {
        if (!Guid.TryParse(_customerId, out var id) || id == Guid.Empty)
        {
            return;
        }

        var c = _customers.SingleOrDefault(x => x.Id == id);
        if (c is null)
        {
            return;
        }

        _customerName = c.Name;
        _customerTaxRegistrationNo = c.TaxRegistrationNo;
    }

    private async Task OnSelectedProductChanged(ChangeEventArgs e)
    {
        _selectedProductId = e.Value?.ToString() ?? "";
        _selectedProductUnitId = "";
        _selectedUnits = [];

        if (!Guid.TryParse(_selectedProductId, out var productId) || productId == Guid.Empty)
        {
            return;
        }

        if (_unitsByProductId.TryGetValue(productId, out var cached))
        {
            _selectedUnits = cached;
            var def = cached.FirstOrDefault(x => x.IsDefault);
            _selectedProductUnitId = def is null ? "" : def.Id.ToString();
            return;
        }

        try
        {
            var units = await Api.GetAsync<List<UnitOption>>($"catalog/products/{productId}/units");
            _unitsByProductId[productId] = units;
            _selectedUnits = units;
            var def = units.FirstOrDefault(x => x.IsDefault);
            _selectedProductUnitId = def is null ? "" : def.Id.ToString();
        }
        catch
        {
            _selectedUnits = [];
        }
    }

    private void AddSelectedProduct()
    {
        _success = null;
        _error = null;

        if (!Guid.TryParse(_selectedProductId, out var productId) || productId == Guid.Empty)
        {
            return;
        }

        var p = _products.SingleOrDefault(x => x.Id == productId);
        if (p is null)
        {
            return;
        }

        var (unitId, unitName, unitFactor) = GetSelectedUnit();
        var price = decimal.Round(p.Price * unitFactor, 3, MidpointRounding.AwayFromZero);

        var taxPercent = 0m;
        if (p.TaxRateId is not null && _taxPercentByRateId.TryGetValue(p.TaxRateId.Value, out var percent))
        {
            taxPercent = percent;
        }

        _lines.Add(new CartLine
        {
            ProductId = p.Id,
            Name = p.Name,
            Sku = p.Sku,
            PrimaryBarcode = p.PrimaryBarcode,
            ProductUnitId = unitId,
            UnitName = unitName,
            UnitFactor = unitFactor,
            Qty = 1m,
            UnitPrice = price,
            Discount = p.DefaultDiscount,
            TaxPercent = taxPercent
        });

        _selectedProductId = "";
        _selectedProductUnitId = "";
        _selectedUnits = [];
        _cashTendered = _paymentMethod == "Cash" ? GrandTotal : 0;
    }

    private (Guid? UnitId, string? UnitName, decimal UnitFactor) GetSelectedUnit()
    {
        if (!string.IsNullOrWhiteSpace(_selectedProductUnitId) &&
            Guid.TryParse(_selectedProductUnitId, out var unitId) &&
            unitId != Guid.Empty)
        {
            var unit = _selectedUnits.SingleOrDefault(x => x.Id == unitId);
            if (unit is not null)
            {
                return (unitId, unit.Name, unit.Factor <= 0 ? 1m : unit.Factor);
            }
        }

        return (null, null, 1m);
    }

    private async Task OnBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LookupAndAdd();
        }
    }

    private async Task LookupAndAdd()
    {
        _success = null;
        _error = null;

        var code = _barcode.Trim();
        if (string.IsNullOrWhiteSpace(code))
        {
            return;
        }

        _busy = true;
        try
        {
            var item = await Api.GetAsync<BarcodeLookup>($"catalog/lookup/barcode/{Uri.EscapeDataString(code)}");
            var p = _products.SingleOrDefault(x => x.Id == item.ProductId);
            if (p is null)
            {
                _error = L["Sales.BarcodeNotFound"].Value;
                return;
            }

            var units = await GetUnitsAsync(item.ProductId);
            var def = units.FirstOrDefault(x => x.IsDefault);
            var unitId = def?.Id;
            var unitName = def?.Name;
            var unitFactor = def?.Factor <= 0 ? 1m : def?.Factor ?? 1m;
            var price = decimal.Round(p.Price * unitFactor, 3, MidpointRounding.AwayFromZero);

            var taxPercent = 0m;
            if (p.TaxRateId is not null && _taxPercentByRateId.TryGetValue(p.TaxRateId.Value, out var percent))
            {
                taxPercent = percent;
            }

            _lines.Add(new CartLine
            {
                ProductId = p.Id,
                Name = p.Name,
                Sku = p.Sku,
                PrimaryBarcode = p.PrimaryBarcode,
                ProductUnitId = unitId,
                UnitName = unitName,
                UnitFactor = unitFactor,
                Qty = 1m,
                UnitPrice = price,
                Discount = p.DefaultDiscount,
                TaxPercent = taxPercent
            });

            _barcode = "";
            _cashTendered = _paymentMethod == "Cash" ? GrandTotal : 0;
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        catch
        {
            _error = L["Sales.BarcodeNotFound"].Value;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<List<UnitOption>> GetUnitsAsync(Guid productId)
    {
        if (_unitsByProductId.TryGetValue(productId, out var cached))
        {
            return cached;
        }

        var units = await Api.GetAsync<List<UnitOption>>($"catalog/products/{productId}/units");
        _unitsByProductId[productId] = units;
        return units;
    }

    private void RemoveLine(int index)
    {
        if (index < 0 || index >= _lines.Count)
        {
            return;
        }

        _lines.RemoveAt(index);
        _cashTendered = _paymentMethod == "Cash" ? GrandTotal : 0;
    }

    private void ClearLines()
    {
        _lines.Clear();
        _barcode = "";
        _receipt = null;
        _qrSvg = null;
        _cashTendered = 0;
    }

    private void ClearCartOnly()
    {
        _lines.Clear();
        _barcode = "";
        _cashTendered = 0;
    }

    private (decimal Total, decimal Vat, decimal BeforeVat) ComputeTotals(decimal invoiceDiscount)
    {
        if (_lines.Count == 0)
        {
            return (0m, 0m, 0m);
        }

        var lineTotals = _lines.Select(LineTotal).ToArray();
        var discount = invoiceDiscount < 0 ? 0m : decimal.Round(invoiceDiscount, 3, MidpointRounding.AwayFromZero);
        var shares = AllocateDiscountShares(lineTotals, discount);

        decimal total = 0;
        decimal vat = 0;
        for (var i = 0; i < _lines.Count; i++)
        {
            var adj = decimal.Round(lineTotals[i] - shares[i], 3, MidpointRounding.AwayFromZero);
            if (adj < 0)
            {
                adj = 0;
            }

            total += adj;
            vat += IncludedVat(adj, _lines[i].TaxPercent);
        }

        total = decimal.Round(total, 3, MidpointRounding.AwayFromZero);
        vat = decimal.Round(vat, 3, MidpointRounding.AwayFromZero);
        var beforeVat = decimal.Round(total - vat, 3, MidpointRounding.AwayFromZero);
        return (total, vat, beforeVat);
    }

    private static decimal[] AllocateDiscountShares(IReadOnlyList<decimal> lineTotals, decimal invoiceDiscount)
    {
        var n = lineTotals.Count;
        var shares = new decimal[n];
        if (n == 0 || invoiceDiscount <= 0)
        {
            return shares;
        }

        var weights = new decimal[n];
        decimal sum = 0;
        for (var i = 0; i < n; i++)
        {
            var w = lineTotals[i];
            if (w < 0)
            {
                w = 0;
            }

            w = decimal.Round(w, 3, MidpointRounding.AwayFromZero);
            weights[i] = w;
            sum += w;
        }

        sum = decimal.Round(sum, 3, MidpointRounding.AwayFromZero);
        if (sum <= 0)
        {
            return shares;
        }

        invoiceDiscount = decimal.Round(invoiceDiscount, 3, MidpointRounding.AwayFromZero);
        if (invoiceDiscount > sum)
        {
            invoiceDiscount = sum;
        }

        decimal remaining = invoiceDiscount;

        for (var i = 0; i < n - 1; i++)
        {
            var w = weights[i];
            if (w <= 0 || remaining <= 0)
            {
                continue;
            }

            var raw = invoiceDiscount * w / sum;
            var share = decimal.Round(raw, 3, MidpointRounding.AwayFromZero);
            if (share > w)
            {
                share = w;
            }

            if (share > remaining)
            {
                share = remaining;
            }

            shares[i] = share;
            remaining = decimal.Round(remaining - share, 3, MidpointRounding.AwayFromZero);
        }

        if (remaining > 0)
        {
            for (var i = n - 1; i >= 0 && remaining > 0; i--)
            {
                var cap = weights[i] - shares[i];
                if (cap <= 0)
                {
                    continue;
                }

                var add = remaining > cap ? cap : remaining;
                add = decimal.Round(add, 3, MidpointRounding.AwayFromZero);
                shares[i] = decimal.Round(shares[i] + add, 3, MidpointRounding.AwayFromZero);
                remaining = decimal.Round(remaining - add, 3, MidpointRounding.AwayFromZero);
            }
        }

        return shares;
    }

    private async Task SaveSale()
    {
        _success = null;
        _error = null;

        if (_lines.Count == 0)
        {
            return;
        }

        foreach (var l in _lines)
        {
            if (l.Qty <= 0 || l.UnitPrice < 0 || l.Discount < 0 || LineTotal(l) < 0)
            {
                _error = L["Sales.InvalidLine"].Value;
                return;
            }
        }

        var lineTotals = _lines.Select(LineTotal).ToArray();
        var maxDiscount = decimal.Round(lineTotals.Sum(), 3, MidpointRounding.AwayFromZero);
        var invoiceDiscount = _invoiceDiscount < 0 ? 0m : decimal.Round(_invoiceDiscount, 3, MidpointRounding.AwayFromZero);
        if (invoiceDiscount > maxDiscount)
        {
            _error = $"{L["Sales.InvoiceDiscount"].Value} > {maxDiscount}";
            return;
        }

        if (GrandTotal <= 0)
        {
            _error = L["Sales.InvalidTotal"].Value;
            return;
        }

        if (_paymentMethod == "Cash" && _cashTendered < GrandTotal)
        {
            _cashTendered = GrandTotal;
        }

        Guid? customerId = null;
        if (Guid.TryParse(_customerId, out var cid) && cid != Guid.Empty)
        {
            customerId = cid;
        }

        if (_paymentMethod == "OnAccount" && customerId is null)
        {
            _error = L["Sales.CustomerRequiredForOnAccount"].Value;
            return;
        }

        var payments = new List<PaymentRequest>();
        if (_paymentMethod == "Cash")
        {
            payments.Add(new PaymentRequest { Method = "Cash", Amount = _cashTendered <= 0 ? GrandTotal : _cashTendered });
        }
        else if (_paymentMethod == "Visa" || _paymentMethod == "Bank")
        {
            payments.Add(new PaymentRequest { Method = _paymentMethod, Amount = GrandTotal, ReferenceNo = _referenceNo });
        }
        else
        {
            payments.Add(new PaymentRequest { Method = "OnAccount", Amount = GrandTotal });
        }

        var shares = AllocateDiscountShares(lineTotals, invoiceDiscount);

        var request = new CreateSaleRequest
        {
            BranchId = Session.BranchId,
            CustomerId = customerId,
            Items = _lines.Select((x, i) => new SaleItemRequest
            {
                ProductId = x.ProductId,
                ProductUnitId = x.ProductUnitId,
                Qty = x.Qty,
                UnitPrice = x.UnitPrice,
                Discount = x.Discount + shares[i]
            }).ToList(),
            Payments = payments,
            Note = string.IsNullOrWhiteSpace(_note) ? null : _note.Trim(),
            CustomerName = string.IsNullOrWhiteSpace(_customerName) ? null : _customerName.Trim(),
            CustomerTaxRegistrationNo = string.IsNullOrWhiteSpace(_customerTaxRegistrationNo) ? null : _customerTaxRegistrationNo.Trim(),
            CustomerAddress = null,
            At = new DateTimeOffset(_atDate, TimeZoneInfo.Local.GetUtcOffset(_atDate))
        };

        _busy = true;
        try
        {
            _saleIdempotencyKey ??= Guid.NewGuid().ToString();
            var response = await Api.PostAsync("pos/sales", request, new Dictionary<string, string>
            {
                ["Idempotency-Key"] = _saleIdempotencyKey
            });
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<CreateSaleResponse>();
            if (created is null || created.SaleId == Guid.Empty)
            {
                _error = "Invalid response.";
                return;
            }

            var details = await Api.GetAsync<SaleDetailsResponse>($"pos/sales/{created.SaleId}");
            _receipt = SaleReceipt.From(details);
            _qrSvg = BuildQrSvg(details);
            _success = $"{L["Common.Added"]} {details.SaleNo}";
            _lastInvoiceDiscount = invoiceDiscount;
            _saleIdempotencyKey = null;
            _invoiceDiscount = 0;
            ClearCartOnly();
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static decimal LineTotal(CartLine line)
        => decimal.Round((line.Qty * line.UnitPrice) - line.Discount, 3, MidpointRounding.AwayFromZero);

    private static decimal IncludedVat(decimal total, decimal taxPercent)
    {
        if (taxPercent <= 0)
        {
            return 0m;
        }

        var rate = taxPercent > 1 ? (taxPercent / 100m) : taxPercent;
        var baseAmount = total / (1m + rate);
        return decimal.Round(total - baseAmount, 3, MidpointRounding.AwayFromZero);
    }

    private string? BuildQrSvg(SaleDetailsResponse sale)
    {
        try
        {
            var payload = $"SaleNo={sale.SaleNo};At={sale.At:O};Total={sale.Total};VAT={sale.TaxTotal}";
            var qr = QrCode.EncodeText(payload, QrCode.Ecc.Medium);
            return qr.ToSvgString(2);
        }
        catch
        {
            return null;
        }
    }

    private void Print()
    {
        JS.InvokeVoidAsync("window.print");
    }

    private void RedirectToLogin()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/login" : $"/login?return=/{Uri.EscapeDataString(relative)}";
        Nav.NavigateTo(target);
    }

