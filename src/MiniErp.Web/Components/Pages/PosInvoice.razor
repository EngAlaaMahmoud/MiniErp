                CustomerName = d.CustomerName,
                CustomerTaxRegistrationNo = d.CustomerTaxRegistrationNo,
                CustomerAddress = d.CustomerAddress,
                Lines = d.Items.Select(x => new SaleReceiptLine
                {
                    ProductName = x.ProductName,
                    Qty = x.Qty,
                    UnitPrice = x.UnitPrice,
                    Discount = x.Discount,
