@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiClient Api
@inject ApiSession Session
@inject NavigationManager Nav

<PageTitle>تسجيل الدخول</PageTitle>

<div class="container" style="max-width: 520px;">
    <h1 class="h3 mb-3">تسجيل الدخول</h1>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <EditForm Model="_model" OnValidSubmit="OnSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label class="form-label">TenantId</label>
            <InputText class="form-control" @bind-Value="_model.TenantId" />
        </div>

        <div class="mb-2">
            <label class="form-label">BranchId</label>
            <InputText class="form-control" @bind-Value="_model.BranchId" />
        </div>

        <div class="mb-2">
            <label class="form-label">DeviceId</label>
            <InputText class="form-control" @bind-Value="_model.DeviceId" />
        </div>

        <div class="mb-2">
            <label class="form-label">اسم المستخدم</label>
            <InputText class="form-control" @bind-Value="_model.UserName" />
        </div>

        <div class="mb-3">
            <label class="form-label">PIN</label>
            <InputText class="form-control" type="password" @bind-Value="_model.Pin" />
        </div>

        <button class="btn btn-primary w-100" disabled="@_busy">دخول</button>
    </EditForm>

    <div class="mt-4 small text-muted">
        بيانات الديمو (Development):
        <div><code>TenantId</code>: <code>11111111-1111-1111-1111-111111111111</code></div>
        <div><code>BranchId</code>: <code>22222222-2222-2222-2222-222222222222</code></div>
        <div><code>DeviceId</code>: <code>33333333-3333-3333-3333-333333333333</code></div>
        <div><code>User</code>: <code>owner</code> / <code>PIN</code>: <code>1234</code></div>
    </div>
</div>

@code {
    private LoginModel _model = new()
    {
        TenantId = "11111111-1111-1111-1111-111111111111",
        BranchId = "22222222-2222-2222-2222-222222222222",
        DeviceId = "33333333-3333-3333-3333-333333333333",
        UserName = "owner"
    };

    private bool _busy;
    private string? _error;

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync();
        if (Session.IsLoggedIn)
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task OnSubmit()
    {
        _error = null;
        _busy = true;
        try
        {
            if (!Guid.TryParse(_model.TenantId, out var tenantId) || tenantId == Guid.Empty)
            {
                _error = "TenantId غير صحيح";
                return;
            }

            if (!Guid.TryParse(_model.BranchId, out var branchId) || branchId == Guid.Empty)
            {
                _error = "BranchId غير صحيح";
                return;
            }

            if (!Guid.TryParse(_model.DeviceId, out var deviceId) || deviceId == Guid.Empty)
            {
                _error = "DeviceId غير صحيح";
                return;
            }

            PinLoginResult result;
            try
            {
                result = await Api.PinLoginAsync(tenantId, deviceId, _model.UserName, _model.Pin);
            }
            catch (Exception ex)
            {
                _error = $"تعذر الاتصال بالسيرفر: {ex.Message}";
                return;
            }

            if (!result.Success || string.IsNullOrWhiteSpace(result.JsonBody))
            {
                _error = "بيانات الدخول غير صحيحة.";
                return;
            }

            var parsed = System.Text.Json.JsonSerializer.Deserialize<PinLoginResponse>(result.JsonBody, new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
            if (parsed is null || string.IsNullOrWhiteSpace(parsed.AccessToken))
            {
                _error = "فشل تسجيل الدخول.";
                return;
            }

            await Session.SetAsync(tenantId, deviceId, branchId, parsed.AccessToken, parsed.UserName, MapRole(parsed.Role));
            Nav.NavigateTo("/");
        }
        finally
        {
            _busy = false;
        }
    }

    private static string MapRole(int role)
        => role switch
        {
            1 => "Cashier",
            2 => "Manager",
            3 => "Owner",
            _ => $"Role:{role}"
        };

    private sealed class LoginModel
    {
        public string TenantId { get; set; } = "";
        public string BranchId { get; set; } = "";
        public string DeviceId { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Pin { get; set; } = "";
    }

    private sealed class PinLoginResponse
    {
        public string AccessToken { get; set; } = "";
        public Guid UserId { get; set; }
        public string UserName { get; set; } = "";
        public int Role { get; set; }
        public Guid TenantId { get; set; }
        public Guid DeviceId { get; set; }
    }
}
