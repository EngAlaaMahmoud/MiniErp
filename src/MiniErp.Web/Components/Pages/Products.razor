@page "/products"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json

<PageTitle>@L["Nav.Products"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Nav.Products"]</h1>
        <a class="btn btn-outline-secondary" href="/">@L["Common.Back"]</a>
    </div>

    @if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else
    {
        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex gap-2 mb-2">
                            <input class="form-control" placeholder="@L["Products.SearchPlaceholder"]" @bind="_search" @bind:event="oninput" />
                            <button class="btn btn-outline-primary" @onclick="Load">@L["Common.Refresh"]</button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="alert alert-danger">@_error</div>
                        }

                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th class="text-end">@L["Products.Col.Vat"]</th>
                                        <th class="text-end">@L["Products.Col.TableTax"]</th>
                                        <th class="text-end">@L["Products.Col.ServiceFee"]</th>
                                        <th class="text-end">@L["Products.Col.AdditionalTaxes"]</th>
                                        <th class="text-end">@L["Products.Col.AdditionalFees"]</th>
                                        <th class="text-end">@L["Products.Col.PriceAfterDiscount"]</th>
                                        <th class="text-end">@L["Products.Col.Discount"]</th>
                                        <th class="text-end">@L["Products.Col.UnitPrice"]</th>
                                        <th>@L["Products.Col.ProductName"]</th>
                                        <th>@L["Products.Col.DescriptionModel"]</th>
                                        <th>@L["Products.Col.CompanyName"]</th>
                                        <th>@L["Products.Col.ProductGroup"]</th>
                                        <th>@L["Products.Col.InternalCode"]</th>
                                        <th>@L["Products.Col.EgsCode"]</th>
                                        <th>@L["Common.Active"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _products)
                                    {
                                        <tr>
                                            <td class="text-end">@LookupName(_taxRateNameById, p.TaxRateId)</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end">@decimal.Round(p.Price - p.DefaultDiscount, 3)</td>
                                            <td class="text-end">@p.DefaultDiscount</td>
                                            <td class="text-end">@p.Price</td>
                                            <td>@p.Name</td>
                                            <td class="text-muted">@p.Description</td>
                                            <td class="text-muted">@p.BrandName</td>
                                            <td>@LookupName(_categoryNameById, p.CategoryId)</td>
                                            <td class="text-muted">@p.Sku</td>
                                            <td class="text-muted">@p.PrimaryBarcode</td>
                                            <td>@(p.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectForEdit(p)">@L["Common.Edit"]</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Products.AddTitle"]</div>
                        <EditForm Model="_create" OnValidSubmit="Create">
                            <DataAnnotationsValidator />
                            <div class="mb-2">
                                <label class="form-label">@L["Products.Field.ProductName"]</label>
                                <InputText class="form-control" @bind-Value="_create.Name" />
                            </div>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.InternalCode"]</label>
                                    <InputText class="form-control" @bind-Value="_create.Sku" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.EgsCode"]</label>
                                    <InputText class="form-control" @bind-Value="_create.PrimaryBarcode" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.ProductGroup"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.CategoryId">
                                        <option value="">-</option>
                                        @foreach (var c in _categories)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.UnitMeasure"]</label>
                                    <InputText class="form-control" @bind-Value="_create.DefaultUnitName" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.CompanyName"]</label>
                                    <InputText class="form-control" @bind-Value="_create.BrandName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.DescriptionModel"]</label>
                                    <InputText class="form-control" @bind-Value="_create.Description" />
                                </div>
                            </div>
                            <div class="row g-2">
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.UnitPrice"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.Price" />
                                </div>
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.Cost"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.Cost" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.Discount"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.DefaultDiscount" />
                                </div>
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.PriceAfterDiscount"]</label>
                                    <input class="form-control text-end" value="@decimal.Round(_create.Price - _create.DefaultDiscount, 3)" readonly />
                                </div>
                            </div>

                            <div class="row g-2 mt-1">
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.VatRate"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.TaxRateId">
                                        <option value="">-</option>
                                        @foreach (var r in _taxRates)
                                        {
                                            <option value="@r.Id">@r.Name (@(r.Percent * 100)%)</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.TaxCodeSales"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.SalesTaxTypeId">
                                        <option value="">-</option>
                                        @foreach (var t in _taxTypes)
                                        {
                                            <option value="@t.Id">@t.MainCode/@t.SubCode - @t.TaxType</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.ReorderLevel"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.ReorderLevel" />
                                </div>
                            </div>
                            <div class="form-check mt-2 mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_create.IsActive" />
                                <label class="form-check-label">@L["Common.Active"]</label>
                            </div>
                            <button class="btn btn-primary w-100" disabled="@_busy">@L["Common.Save"]</button>
                        </EditForm>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Products.EditTitle"]</div>
                        @if (_edit is null)
                        {
                            <div class="text-muted">@L["Products.SelectToEdit"]</div>
                        }
                        else
                        {
                            <EditForm Model="_edit" OnValidSubmit="SaveEdit">
                                <DataAnnotationsValidator />
                                <div class="mb-2">
                                    <label class="form-label">@L["Products.Field.ProductName"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Name" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">@L["Products.Field.InternalCode"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Sku" />
                                </div>
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.CompanyName"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.BrandName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.DescriptionModel"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.Description" />
                                    </div>
                                </div>
                                <div class="row g-2 mt-1">
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.UnitMeasure"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.DefaultUnitName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.Discount"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.DefaultDiscount" />
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col">
                                        <label class="form-label">@L["Products.Field.UnitPrice"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.Price" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label">@L["Products.Field.Cost"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.Cost" />
                                    </div>
                                </div>

                                <div class="row g-2 mt-1">
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.ProductGroup"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.CategoryId">
                                            <option value="">-</option>
                                            @foreach (var c in _categories)
                                            {
                                                <option value="@c.Id">@c.Name</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.VatRate"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.TaxRateId">
                                            <option value="">-</option>
                                            @foreach (var r in _taxRates)
                                            {
                                                <option value="@r.Id">@r.Name (@(r.Percent * 100)%)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.TaxCodeSales"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.SalesTaxTypeId">
                                            <option value="">-</option>
                                            @foreach (var t in _taxTypes)
                                            {
                                                <option value="@t.Id">@t.MainCode/@t.SubCode - @t.TaxType</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.ReorderLevel"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.ReorderLevel" />
                                    </div>
                                </div>
                                <div class="form-check mt-2 mb-3">
                                    <InputCheckbox class="form-check-input" @bind-Value="_edit.IsActive" />
                                    <label class="form-check-label">@L["Common.Active"]</label>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">إضافة باركود</label>
                                    <div class="d-flex gap-2">
                                        <InputText class="form-control" @bind-Value="_barcode" />
                                        <button class="btn btn-outline-primary" type="button" @onclick="AddBarcode">إضافة</button>
                                    </div>
                                </div>

                                <hr />

                                <div class="fw-bold mb-2">الوحدات</div>
                                @if (_unitsBusy)
                                {
                                    <div class="text-muted">Loading...</div>
                                }
                                else
                                {
                                    @if (!string.IsNullOrWhiteSpace(_unitError))
                                    {
                                        <div class="alert alert-danger">@_unitError</div>
                                    }

                                    @if (_units.Count == 0)
                                    {
                                        <div class="text-muted mb-2">لا توجد وحدات (سيتم إنشاء وحدة افتراضية عند إضافة منتج).</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive mb-2">
                                            <table class="table table-sm table-striped align-middle">
                                                <thead>
                                                    <tr>
                                                        <th>الاسم</th>
                                                        <th class="text-end">Factor</th>
                                                        <th>Default</th>
                                                        <th>نشط</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var u in _units)
                                                    {
                                                        <tr>
                                                            <td>@u.Name</td>
                                                            <td class="text-end">@u.Factor</td>
                                                            <td>@(u.IsDefault ? "نعم" : "لا")</td>
                                                            <td>@(u.IsActive ? "نعم" : "لا")</td>
                                                            <td class="text-end">
                                                                <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => SelectUnitForEdit(u)">تعديل</button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                    <div class="fw-bold mb-2">@(_unitEdit is null ? "إضافة وحدة" : "تعديل وحدة")</div>
                                    <div class="row g-2">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">الاسم</label>
                                            <InputText class="form-control" @bind-Value="_unitForm.Name" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Factor (كم وحدة أساسية)</label>
                                            <input class="form-control" type="number" step="0.001" @bind-value="_unitForm.Factor" @bind-value:event="oninput" />
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check mt-4">
                                                <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsDefault" />
                                                <label class="form-check-label">Default</label>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check mt-4">
                                                <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsActive" />
                                                <label class="form-check-label">نشط</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-outline-primary" type="button" @onclick="SaveUnit" disabled="@_busy">حفظ</button>
                                        @if (_unitEdit is not null)
                                        {
                                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearUnitEdit" disabled="@_busy">إلغاء</button>
                                        }
                                    </div>
                                }

                                <button class="btn btn-success w-100" disabled="@_busy">حفظ التعديلات</button>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _busy;
    private string? _error;
    private string _search = "";
    private List<ProductItem> _products = [];
    private List<CategoryItem> _categories = [];
    private List<TaxRateItem> _taxRates = [];
    private List<TaxTypeItem> _taxTypes = [];

    private Dictionary<Guid, string> _categoryNameById = [];
    private Dictionary<Guid, string> _taxRateNameById = [];
    private Dictionary<Guid, string> _taxTypeNameById = [];
    private CreateProductModel _create = new() { IsActive = true };
    private EditProductModel? _edit;
    private string _barcode = "";
    private bool _initialLoadDone;

    private bool _unitsBusy;
    private string? _unitError;
    private List<ProductUnitItem> _units = [];
    private ProductUnitItem? _unitEdit;
    private UnitFormModel _unitForm = new();

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone)
        {
            return;
        }

        _initialLoadDone = true;
        await Session.EnsureLoadedAsync();
        if (Session.IsLoggedIn)
        {
            await Load();
        }

        StateHasChanged();
    }

    private async Task LoadLookups()
    {
        _categories = await Api.GetAsync<List<CategoryItem>>("catalog/categories");
        _taxRates = await Api.GetAsync<List<TaxRateItem>>("taxes/rates");
        _taxTypes = await Api.GetAsync<List<TaxTypeItem>>("taxes/types");

        _categoryNameById = _categories.ToDictionary(x => x.Id, x => x.Name);
        _taxRateNameById = _taxRates.ToDictionary(x => x.Id, x => x.Name);
        _taxTypeNameById = _taxTypes.ToDictionary(x => x.Id, x => $"{x.MainCode}/{x.SubCode}");

        if (_create.CategoryId is null && _categories.Count == 1)
        {
            _create.CategoryId = _categories[0].Id;
        }

        if (_create.TaxRateId is null && _taxRates.Count == 1)
        {
            _create.TaxRateId = _taxRates[0].Id;
        }

        if (_create.SalesTaxTypeId is null && _taxTypes.Count == 1)
        {
            _create.SalesTaxTypeId = _taxTypes[0].Id;
        }
    }

    private async Task Load()
    {
        _error = null;
        try
        {
            await LoadLookups();
            var q = string.IsNullOrWhiteSpace(_search) ? "" : $"?search={Uri.EscapeDataString(_search)}";
            _products = await Api.GetAsync<List<ProductItem>>($"catalog/products{q}");
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Create()
    {
        _busy = true;
        _error = null;
        try
        {
            if (_create.TaxRateId is null || _create.TaxRateId.Value == Guid.Empty)
            {
                _error = L["Products.Error.VatRateRequired"].Value;
                return;
            }

            var response = await Api.PostAsync("catalog/products", new
            {
                name = _create.Name,
                sku = string.IsNullOrWhiteSpace(_create.Sku) ? null : _create.Sku,
                brandName = string.IsNullOrWhiteSpace(_create.BrandName) ? null : _create.BrandName,
                description = string.IsNullOrWhiteSpace(_create.Description) ? null : _create.Description,
                price = _create.Price,
                defaultDiscount = _create.DefaultDiscount,
                defaultUnitName = string.IsNullOrWhiteSpace(_create.DefaultUnitName) ? null : _create.DefaultUnitName,
                cost = _create.Cost,
                categoryId = _create.CategoryId,
                taxRateId = _create.TaxRateId,
                salesTaxTypeId = _create.SalesTaxTypeId,
                reorderLevel = _create.ReorderLevel,
                isActive = _create.IsActive
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<ProductItem>();
            if (created is not null && !string.IsNullOrWhiteSpace(_create.PrimaryBarcode))
            {
                await Api.PostAsync($"catalog/products/{created.Id}/barcodes", new { code = _create.PrimaryBarcode.Trim() });
            }

            _create = new CreateProductModel { IsActive = true };
            if (_create.CategoryId is null && _categories.Count == 1)
            {
                _create.CategoryId = _categories[0].Id;
            }
            if (_create.TaxRateId is null && _taxRates.Count == 1)
            {
                _create.TaxRateId = _taxRates[0].Id;
            }
            if (_create.SalesTaxTypeId is null && _taxTypes.Count == 1)
            {
                _create.SalesTaxTypeId = _taxTypes[0].Id;
            }
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SelectForEdit(ProductItem p)
    {
        _edit = new EditProductModel
        {
            Id = p.Id,
            Name = p.Name,
            Sku = p.Sku,
            BrandName = p.BrandName,
            Description = p.Description,
            Price = p.Price,
            DefaultDiscount = p.DefaultDiscount,
            DefaultUnitName = p.DefaultUnitName,
            Cost = p.Cost,
            CategoryId = p.CategoryId,
            TaxRateId = p.TaxRateId,
            SalesTaxTypeId = p.SalesTaxTypeId,
            ReorderLevel = p.ReorderLevel,
            IsActive = p.IsActive
        };
        if (_edit.TaxRateId is null && _taxRates.Count == 1)
        {
            _edit.TaxRateId = _taxRates[0].Id;
        }
        _barcode = "";
        await LoadUnits(p.Id);
    }

    private async Task SaveEdit()
    {
        if (_edit is null)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            if (_edit.TaxRateId is null || _edit.TaxRateId.Value == Guid.Empty)
            {
                _error = L["Products.Error.VatRateRequired"].Value;
                return;
            }

            var response = await Api.PutAsync($"catalog/products/{_edit.Id}", new
            {
                name = _edit.Name,
                sku = string.IsNullOrWhiteSpace(_edit.Sku) ? null : _edit.Sku,
                brandName = string.IsNullOrWhiteSpace(_edit.BrandName) ? null : _edit.BrandName,
                description = string.IsNullOrWhiteSpace(_edit.Description) ? null : _edit.Description,
                price = _edit.Price,
                defaultDiscount = _edit.DefaultDiscount,
                defaultUnitName = string.IsNullOrWhiteSpace(_edit.DefaultUnitName) ? null : _edit.DefaultUnitName,
                cost = _edit.Cost,
                categoryId = _edit.CategoryId,
                taxRateId = _edit.TaxRateId,
                salesTaxTypeId = _edit.SalesTaxTypeId,
                reorderLevel = _edit.ReorderLevel,
                isActive = _edit.IsActive
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            await Load();
            await LoadUnits(_edit.Id);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadUnits(Guid productId)
    {
        _unitsBusy = true;
        _unitError = null;
        try
        {
            _units = await Api.GetAsync<List<ProductUnitItem>>($"catalog/products/{productId}/units");
        }
        catch (ApiHttpException ex)
        {
            _unitError = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _unitsBusy = false;
        }
    }

    private void SelectUnitForEdit(ProductUnitItem unit)
    {
        _unitEdit = unit;
        _unitForm = new UnitFormModel
        {
            Name = unit.Name,
            Factor = unit.Factor,
            IsDefault = unit.IsDefault,
            IsActive = unit.IsActive
        };
    }

    private void ClearUnitEdit()
    {
        _unitEdit = null;
        _unitForm = new UnitFormModel();
        _unitError = null;
    }

    private async Task SaveUnit()
    {
        if (_edit is null)
        {
            return;
        }

        _unitError = null;
        if (string.IsNullOrWhiteSpace(_unitForm.Name) || _unitForm.Factor <= 0)
        {
            _unitError = "بيانات الوحدة غير صحيحة.";
            return;
        }

        _busy = true;
        try
        {
            HttpResponseMessage response;
            if (_unitEdit is null)
            {
                response = await Api.PostAsync($"catalog/products/{_edit.Id}/units", new
                {
                    name = _unitForm.Name.Trim(),
                    factor = _unitForm.Factor,
                    isDefault = _unitForm.IsDefault,
                    isActive = _unitForm.IsActive
                });
            }
            else
            {
                response = await Api.PutAsync($"catalog/products/{_edit.Id}/units/{_unitEdit.Id}", new
                {
                    name = _unitForm.Name.Trim(),
                    factor = _unitForm.Factor,
                    isDefault = _unitForm.IsDefault,
                    isActive = _unitForm.IsActive
                });
            }

            if (!response.IsSuccessStatusCode)
            {
                _unitError = await response.Content.ReadAsStringAsync();
                return;
            }

            ClearUnitEdit();
            await LoadUnits(_edit.Id);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AddBarcode()
    {
        if (_edit is null || string.IsNullOrWhiteSpace(_barcode))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var response = await Api.PostAsync($"catalog/products/{_edit.Id}/barcodes", new { code = _barcode.Trim() });
            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            _barcode = "";
        }
        finally
        {
            _busy = false;
        }
    }

