                                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveTaxRow(_create, i)" disabled="@_busy">×</button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <td colspan="3" class="text-end"><strong>@L["Products.Col.AdditionalTaxes"]</strong></td>
                                                                <td class="text-end"><strong>@((AdditionalTaxesPercent(_create) * 100).ToString("0.######"))%</strong></td>
                                                                <td class="text-end"><strong>@AdditionalTaxesValue(_create)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Col.Vat"] (@((VatPercent(_create) * 100).ToString("0.######"))%)</strong></td>
                                                                <td class="text-end"><strong>@VatValue(_create)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Taxes.TotalTaxes"]</strong></td>
                                                                <td class="text-end"><strong>@TotalTaxesValue(_create)</strong></td>
