    private IEnumerable<string> GetUniqueMainCodes()
        => _taxTypes
            .Where(x => x.IsActive)
            .Select(x => x.MainCode)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<TaxTypeItem> GetSubCodesByMainCode(string? mainCode)
        => string.IsNullOrWhiteSpace(mainCode)
            ? Enumerable.Empty<TaxTypeItem>()
            : _taxTypes
                .Where(x => x.IsActive)
                .Where(x => string.Equals(x.MainCode, mainCode, StringComparison.OrdinalIgnoreCase))
                .OrderBy(x => x.SubCode, StringComparer.OrdinalIgnoreCase);

    private void AddTaxRow(CreateProductModel model)
    {
        model.Taxes.Add(new ProductTaxRowModel());
        SyncPrimarySalesTaxType(model);
    }

    private void RemoveTaxRow(CreateProductModel model, int index)
    {
        if (index < 0 || index >= model.Taxes.Count)
        {
            return;
        }

        model.Taxes.RemoveAt(index);
        SyncPrimarySalesTaxType(model);
    }

    private void OnTaxMainCodeChanged(CreateProductModel model, ProductTaxRowModel row, ChangeEventArgs e)
    {
        row.MainCode = e.Value?.ToString();
        row.SubCode = null;
        row.SalesTaxTypeId = null;
        SyncPrimarySalesTaxType(model);
    }

    private void OnTaxSubCodeChanged(CreateProductModel model, ProductTaxRowModel row, ChangeEventArgs e)
    {
        row.SubCode = e.Value?.ToString();

        var selected = _taxTypes.FirstOrDefault(x =>
            string.Equals(x.MainCode, row.MainCode, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(x.SubCode, row.SubCode, StringComparison.OrdinalIgnoreCase));

        row.SalesTaxTypeId = selected?.Id;
        SyncPrimarySalesTaxType(model);
    }

    private void SyncPrimarySalesTaxType(CreateProductModel model)
    {
        model.SalesTaxTypeId = model.Taxes
            .Select(x => x.SalesTaxTypeId)
            .FirstOrDefault(x => x is not null && x.Value != Guid.Empty);
    }

    private TaxTypeItem? LookupTaxType(ProductTaxRowModel row)
    {
        if (row.SalesTaxTypeId is not null && row.SalesTaxTypeId.Value != Guid.Empty)
        {
            return _taxTypes.FirstOrDefault(x => x.Id == row.SalesTaxTypeId.Value);
        }

        if (!string.IsNullOrWhiteSpace(row.MainCode) && !string.IsNullOrWhiteSpace(row.SubCode))
        {
            return _taxTypes.FirstOrDefault(x =>
                string.Equals(x.MainCode, row.MainCode, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(x.SubCode, row.SubCode, StringComparison.OrdinalIgnoreCase));
        }

        return null;
    }

    private const string PercentFormat = "0.######";
    private static decimal RoundMoney(decimal value) => decimal.Round(value, 3, MidpointRounding.AwayFromZero);

    private decimal PriceAfterDiscount(CreateProductModel model) => RoundMoney(model.Price - model.DefaultDiscount);

    private decimal VatPercent(CreateProductModel model)
        => model.TaxRateId is null
            ? 0m
            : _taxRates.FirstOrDefault(x => x.Id == model.TaxRateId.Value)?.Percent ?? 0m;

    private decimal AdditionalTaxesPercent(CreateProductModel model)
        => model.Taxes
            .Select(LookupTaxType)
            .Where(x => x is not null)
            .Sum(x => x!.Percent);

    private decimal AdditionalTaxesValue(CreateProductModel model)
    {
        var baseAmount = PriceAfterDiscount(model);
        return RoundMoney(model.Taxes
            .Select(LookupTaxType)
            .Where(x => x is not null)
            .Sum(x => baseAmount * x!.Percent));
    }

    private decimal TaxValue(CreateProductModel model, ProductTaxRowModel row)
    {
        var type = LookupTaxType(row);
        if (type is null)
        {
            return 0m;
        }

        return RoundMoney(PriceAfterDiscount(model) * type.Percent);
    }

    private decimal VatValue(CreateProductModel model)
    {
        var baseAmount = PriceAfterDiscount(model);
        return RoundMoney(baseAmount * VatPercent(model));
    }

    private decimal TotalTaxesValue(CreateProductModel model) => RoundMoney(VatValue(model) + AdditionalTaxesValue(model));

    private decimal PriceAfterTaxes(CreateProductModel model) => RoundMoney(PriceAfterDiscount(model) + TotalTaxesValue(model));

    private async Task LoadProductTaxes(Guid productId)
    {
        _productTaxesBusy = true;
        _productTaxesError = null;
        try
        {
            var items = await Api.GetAsync<List<ProductTaxItem>>($"catalog/products/{productId}/taxes");

            if (_edit is null)
            {
                return;
            }

            _edit.Taxes = items
                .Select(i =>
                {
                    var type = _taxTypes.FirstOrDefault(t => t.Id == i.SalesTaxTypeId);
                    return new ProductTaxRowModel
                    {
                        SalesTaxTypeId = i.SalesTaxTypeId,
                        MainCode = type?.MainCode,
                        SubCode = type?.SubCode
                    };
                })
                .ToList();

            SyncPrimarySalesTaxType(_edit);
        }
        catch (ApiHttpException ex)
        {
            _productTaxesError = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _productTaxesBusy = false;
        }
    }

    private async Task SaveProductTaxes(Guid productId, IReadOnlyList<ProductTaxRowModel> taxes)
    {
        _productTaxesError = null;
        var ids = taxes
            .Select(x => x.SalesTaxTypeId)
            .Where(x => x is not null && x.Value != Guid.Empty)
            .Select(x => x!.Value)
            .Distinct()
            .ToArray();

        var response = await Api.PutAsync($"catalog/products/{productId}/taxes", new { salesTaxTypeIds = ids });
        if (!response.IsSuccessStatusCode)
        {
            _productTaxesError = await response.Content.ReadAsStringAsync();
        }
    }

