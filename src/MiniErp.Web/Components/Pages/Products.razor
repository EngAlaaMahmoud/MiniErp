@page "/products"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@implements IAsyncDisposable

<PageTitle>@L["Nav.Products"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Nav.Products"]</h1>
        <a class="btn btn-outline-secondary" href="/">@L["Common.Back"]</a>
    </div>

    @if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else
    {
        @* Legacy two-column layout (reference)
        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex gap-2 mb-2">
                            <input class="form-control" placeholder="@L["Products.SearchPlaceholder"]" @bind="_search" @bind:event="oninput" />
                            <button class="btn btn-outline-primary" @onclick="Load">@L["Common.Refresh"]</button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="alert alert-danger">@_error</div>
                        }

                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th class="text-end">@L["Products.Col.Vat"]</th>
                                        <th class="text-end">@L["Products.Col.TableTax"]</th>
                                        <th class="text-end">@L["Products.Col.ServiceFee"]</th>
                                        <th class="text-end">@L["Products.Col.AdditionalTaxes"]</th>
                                        <th class="text-end">@L["Products.Col.AdditionalFees"]</th>
                                        <th class="text-end">@L["Products.Col.PriceAfterDiscount"]</th>
                                        <th class="text-end">@L["Products.Col.Discount"]</th>
                                        <th class="text-end">@L["Products.Col.UnitPrice"]</th>
                                        <th>@L["Products.Col.ProductName"]</th>
                                        <th>@L["Products.Col.DescriptionModel"]</th>
                                        <th>@L["Products.Col.CompanyName"]</th>
                                        <th>@L["Products.Col.ProductGroup"]</th>
                                        <th>@L["Products.Col.InternalCode"]</th>
                                        <th>@L["Products.Col.EgsCode"]</th>
                                        <th>@L["Common.Active"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _products)
                                    {
                                        <tr>
                                            <td class="text-end">@LookupName(_taxRateNameById, p.TaxRateId)</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end text-muted">0</td>
                                            <td class="text-end">@decimal.Round(p.Price - p.DefaultDiscount, 3)</td>
                                            <td class="text-end">@p.DefaultDiscount</td>
                                            <td class="text-end">@p.Price</td>
                                            <td>@p.Name</td>
                                            <td class="text-muted">@p.Description</td>
                                            <td class="text-muted">@p.BrandName</td>
                                            <td>@LookupName(_categoryNameById, p.CategoryId)</td>
                                            <td class="text-muted">@p.Sku</td>
                                            <td class="text-muted">@p.PrimaryBarcode</td>
                                            <td>@(p.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectForEdit(p)">@L["Common.Edit"]</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Products.AddTitle"]</div>
                        <EditForm Model="_create" OnValidSubmit="Create">
                            <DataAnnotationsValidator />
                            <div class="mb-2">
                                <label class="form-label">@L["Products.Field.ProductName"]</label>
                                <InputText class="form-control" @bind-Value="_create.Name" />
                            </div>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.InternalCode"]</label>
                                    <InputText class="form-control" @bind-Value="_create.Sku" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.EgsCode"]</label>
                                    <InputText class="form-control" @bind-Value="_create.PrimaryBarcode" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.ProductGroup"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.CategoryId">
                                        <option value="">-</option>
                                        @foreach (var c in _categories)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.UnitMeasure"]</label>
                                    <InputText class="form-control" @bind-Value="_create.DefaultUnitName" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.CompanyName"]</label>
                                    <InputText class="form-control" @bind-Value="_create.BrandName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@L["Products.Field.DescriptionModel"]</label>
                                    <InputText class="form-control" @bind-Value="_create.Description" />
                                </div>
                            </div>
                            <div class="row g-2">
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.UnitPrice"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.Price" />
                                </div>
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.Cost"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.Cost" />
                                </div>
                            </div>
                            <div class="row g-2 mt-1">
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.Discount"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.DefaultDiscount" />
                                </div>
                                <div class="col">
                                    <label class="form-label">@L["Products.Field.PriceAfterDiscount"]</label>
                                    <input class="form-control text-end" value="@decimal.Round(_create.Price - _create.DefaultDiscount, 3)" readonly />
                                </div>
                            </div>

                            <div class="row g-2 mt-1">
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.VatRate"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.TaxRateId">
                                        <option value="">-</option>
                                        @foreach (var r in _taxRates)
                                        {
                                            <option value="@r.Id">@r.Name (@(r.Percent * 100)%)</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.TaxCodeSales"]</label>
                                    <InputSelect class="form-select" @bind-Value="_create.SalesTaxTypeId">
                                        <option value="">-</option>
                                        @foreach (var t in _taxTypes)
                                        {
                                            <option value="@t.Id">@t.MainCode/@t.SubCode - @t.TaxType</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">@L["Products.Field.ReorderLevel"]</label>
                                    <InputNumber class="form-control" @bind-Value="_create.ReorderLevel" />
                                </div>
                            </div>
                            <div class="form-check mt-2 mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_create.IsActive" />
                                <label class="form-check-label">@L["Common.Active"]</label>
                            </div>
                            <button class="btn btn-primary w-100" disabled="@_busy">@L["Common.Save"]</button>
                        </EditForm>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Products.EditTitle"]</div>
                        @if (_edit is null)
                        {
                            <div class="text-muted">@L["Products.SelectToEdit"]</div>
                        }
                        else
                        {
                            <EditForm Model="_edit" OnValidSubmit="SaveEdit">
                                <DataAnnotationsValidator />
                                <div class="mb-2">
                                    <label class="form-label">@L["Products.Field.ProductName"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Name" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">@L["Products.Field.InternalCode"]</label>
                                    <InputText class="form-control" @bind-Value="_edit.Sku" />
                                </div>
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.CompanyName"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.BrandName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.DescriptionModel"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.Description" />
                                    </div>
                                </div>
                                <div class="row g-2 mt-1">
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.UnitMeasure"]</label>
                                        <InputText class="form-control" @bind-Value="_edit.DefaultUnitName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">@L["Products.Field.Discount"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.DefaultDiscount" />
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col">
                                        <label class="form-label">@L["Products.Field.UnitPrice"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.Price" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label">@L["Products.Field.Cost"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.Cost" />
                                    </div>
                                </div>

                                <div class="row g-2 mt-1">
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.ProductGroup"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.CategoryId">
                                            <option value="">-</option>
                                            @foreach (var c in _categories)
                                            {
                                                <option value="@c.Id">@c.Name</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.VatRate"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.TaxRateId">
                                            <option value="">-</option>
                                            @foreach (var r in _taxRates)
                                            {
                                                <option value="@r.Id">@r.Name (@(r.Percent * 100)%)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.TaxCodeSales"]</label>
                                        <InputSelect class="form-select" @bind-Value="_edit.SalesTaxTypeId">
                                            <option value="">-</option>
                                            @foreach (var t in _taxTypes)
                                            {
                                                <option value="@t.Id">@t.MainCode/@t.SubCode - @t.TaxType</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@L["Products.Field.ReorderLevel"]</label>
                                        <InputNumber class="form-control" @bind-Value="_edit.ReorderLevel" />
                                    </div>
                                </div>
                                <div class="form-check mt-2 mb-3">
                                    <InputCheckbox class="form-check-input" @bind-Value="_edit.IsActive" />
                                    <label class="form-check-label">@L["Common.Active"]</label>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">إضافة باركود</label>
                                    <div class="d-flex gap-2">
                                        <InputText class="form-control" @bind-Value="_barcode" />
                                        <button class="btn btn-outline-primary" type="button" @onclick="AddBarcode">إضافة</button>
                                    </div>
                                </div>

                                <hr />

                                <div class="fw-bold mb-2">الوحدات</div>
                                @if (_unitsBusy)
                                {
                                    <div class="text-muted">Loading...</div>
                                }
                                else
                                {
                                    @if (!string.IsNullOrWhiteSpace(_unitError))
                                    {
                                        <div class="alert alert-danger">@_unitError</div>
                                    }

                                    @if (_units.Count == 0)
                                    {
                                        <div class="text-muted mb-2">لا توجد وحدات (سيتم إنشاء وحدة افتراضية عند إضافة منتج).</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive mb-2">
                                            <table class="table table-sm table-striped align-middle">
                                                <thead>
                                                    <tr>
                                                        <th>الاسم</th>
                                                        <th class="text-end">Factor</th>
                                                        <th>Default</th>
                                                        <th>نشط</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var u in _units)
                                                    {
                                                        <tr>
                                                            <td>@u.Name</td>
                                                            <td class="text-end">@u.Factor</td>
                                                            <td>@(u.IsDefault ? "نعم" : "لا")</td>
                                                            <td>@(u.IsActive ? "نعم" : "لا")</td>
                                                            <td class="text-end">
                                                                <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => SelectUnitForEdit(u)">تعديل</button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                    <div class="fw-bold mb-2">@(_unitEdit is null ? "إضافة وحدة" : "تعديل وحدة")</div>
                                    <div class="row g-2">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">الاسم</label>
                                            <InputText class="form-control" @bind-Value="_unitForm.Name" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label">Factor (كم وحدة أساسية)</label>
                                            <input class="form-control" type="number" step="0.001" @bind-value="_unitForm.Factor" @bind-value:event="oninput" />
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check mt-4">
                                                <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsDefault" />
                                                <label class="form-check-label">Default</label>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check mt-4">
                                                <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsActive" />
                                                <label class="form-check-label">نشط</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-outline-primary" type="button" @onclick="SaveUnit" disabled="@_busy">حفظ</button>
                                        @if (_unitEdit is not null)
                                        {
                                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearUnitEdit" disabled="@_busy">إلغاء</button>
                                        }
                                    </div>
                                }

                                <button class="btn btn-success w-100" disabled="@_busy">حفظ التعديلات</button>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        </div>
        *@

        <div class="card">
            <div class="card-body">
                <div class="d-flex gap-2 mb-2">
                    <input class="form-control" placeholder="@L["Products.SearchPlaceholder"]" @bind="_search" @bind:event="oninput" />
                    <button class="btn btn-outline-primary" @onclick="Load" disabled="@_busy">@L["Common.Refresh"]</button>
                    <button class="btn btn-primary" @onclick="OpenCreateModal" disabled="@_busy">@L["Common.Add"]</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th class="text-end">@L["Products.Col.Vat"]</th>
                                <th class="text-end">@L["Products.Col.TableTax"]</th>
                                <th class="text-end">@L["Products.Col.ServiceFee"]</th>
                                <th class="text-end">@L["Products.Col.AdditionalTaxes"]</th>
                                <th class="text-end">@L["Products.Col.AdditionalFees"]</th>
                                <th class="text-end">@L["Products.Col.PriceAfterDiscount"]</th>
                                <th class="text-end">@L["Products.Col.Discount"]</th>
                                <th class="text-end">@L["Products.Col.UnitPrice"]</th>
                                <th>@L["Products.Col.ProductName"]</th>
                                <th>@L["Products.Col.DescriptionModel"]</th>
                                <th>@L["Products.Col.CompanyName"]</th>
                                <th>@L["Products.Col.ProductGroup"]</th>
                                <th>@L["Products.Col.InternalCode"]</th>
                                <th>@L["Products.Col.EgsCode"]</th>
                                <th>@L["Common.Active"]</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in _products)
                            {
                                <tr>
                                    <td class="text-end">@LookupName(_taxRateNameById, p.TaxRateId)</td>
                                    <td class="text-end text-muted">0</td>
                                    <td class="text-end text-muted">0</td>
                                    <td class="text-end text-muted">0</td>
                                    <td class="text-end text-muted">0</td>
                                    <td class="text-end">@decimal.Round(p.Price - p.DefaultDiscount, 3)</td>
                                    <td class="text-end">@p.DefaultDiscount</td>
                                    <td class="text-end">@p.Price</td>
                                    <td>@p.Name</td>
                                    <td class="text-muted">@p.Description</td>
                                    <td class="text-muted">@p.BrandName</td>
                                    <td>@LookupName(_categoryNameById, p.CategoryId)</td>
                                    <td class="text-muted">@p.Sku</td>
                                    <td class="text-muted">@p.PrimaryBarcode</td>
                                    <td>@(p.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="async () => await OpenEditModal(p)">@L["Common.Edit"]</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (_modalMode != ProductModalMode.None)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show" tabindex="-1" role="dialog" aria-modal="true" style="display:block;" data-bs-focus="false" data-bs-backdrop="static">
                <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        @if (_modalMode == ProductModalMode.Create)
                        {
                            <EditForm Model="_create" OnValidSubmit="Create" class="d-flex flex-column" style="min-height:0;">
                                <DataAnnotationsValidator />
                                <div class="modal-header">
                                    <h5 class="modal-title">@L["Products.AddTitle"]</h5>
                                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                                </div>
                                <div class="modal-body overflow-auto" style="min-height:0;">
                                    @if (!string.IsNullOrWhiteSpace(_error))
                                    {
                                        <div class="alert alert-danger">@_error</div>
                                    }

                                    <div class="card mb-3">
                                        <div class="card-header">
                                            <h5 class="m-0">@L["Products.Section.MainInfo"]</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-2 mb-2">
                                                <div class="col-md-6">
                                                    <label class="form-label">@L["Products.Field.ProductName"]</label>
                                                    <InputText class="form-control" @bind-Value="_create.Name" />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">@L["Products.Field.Number"]</label>
                                                    <input class="form-control" value="-" readonly />
                                                </div>
                                            </div>

                                            <div class="row g-2 mb-2">
                                                <div class="col-md-6">
                                                    <label class="form-label">@L["Products.Field.EgsCode"]</label>
                                                    <InputText class="form-control" placeholder="@L["Products.PrimaryBarcode"]" @bind-Value="_create.PrimaryBarcode" />
                                                </div>
                                            </div>

                                            <div class="row g-2 mb-3">
                                                <div class="col-md-4">
                                                    <label class="form-label">@L["Products.Field.InternalCode"]</label>
                                                    <InputText class="form-control" @bind-Value="_create.Sku" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">@L["Products.Field.CompanyName"]</label>
                                                    <InputText class="form-control" @bind-Value="_create.BrandName" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">@L["Products.Field.ProductGroup"]</label>
                                                    <InputSelect class="form-select" @bind-Value="_create.CategoryId">
                                                        <option value="">-</option>
                                                        @foreach (var c in _categories)
                                                        {
                                                            <option value="@c.Id">@c.Name</option>
                                                        }
                                                    </InputSelect>
                                                </div>
                                            </div>

                                            <div class="row g-2 mb-3">
                                                <div class="col-md-4">
                                                    <label class="form-label">@L["Products.Field.DescriptionModel"]</label>
                                                    <InputTextArea class="form-control" rows="3" @bind-Value="_create.Description" />
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="row g-2 align-items-end">
                                                        <div class="col-4">
                                                            <label class="form-label">@L["Products.Field.UnitPrice"]</label>
                                                            <InputNumber class="form-control form-control-sm" @bind-Value="_create.Price" />
                                                        </div>
                                                        <div class="col-4">
                                                            <label class="form-label">@L["Products.Field.Discount"]</label>
                                                            <InputNumber class="form-control form-control-sm" @bind-Value="_create.DefaultDiscount" />
                                                        </div>
                                                        <div class="col-4">
                                                            <label class="form-label">@L["Products.Field.PriceAfterDiscount"]</label>
                                                            <input class="form-control form-control-sm text-end" value="@decimal.Round(_create.Price - _create.DefaultDiscount, 3)" readonly />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row g-2 mb-2">
                                                <div class="col-md-6">
                                                    <label class="form-label">@L["Products.Field.UnitMeasure"]</label>
                                                    <InputText class="form-control" @bind-Value="_create.DefaultUnitName" />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">@L["Products.Field.ReorderLevel"]</label>
                                                    <InputNumber class="form-control" @bind-Value="_create.ReorderLevel" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card mb-3">
                                        <div class="card-header d-flex justify-content-between align-items-center">
                                            <h5 class="m-0">@L["Products.Section.Taxes"]</h5>
