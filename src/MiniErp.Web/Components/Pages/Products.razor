                                </div>
                            </EditForm>
                        }
                        else if (_modalMode == ProductModalMode.Edit && _edit is not null)
                        {
                            <EditForm Model="_edit" OnValidSubmit="SaveEdit" class="d-flex flex-column" style="min-height:0;">
                                <DataAnnotationsValidator />
                                <div class="modal-header">
                                    <h5 class="modal-title">@L["Products.EditTitle"]</h5>
                                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                                </div>
                                <div class="modal-body overflow-auto" style="min-height:0;">
