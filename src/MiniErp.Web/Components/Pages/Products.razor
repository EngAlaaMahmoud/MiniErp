                                                                <td class="text-end"><strong>@AdditionalTaxesValue(_edit)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Col.Vat"] (@((VatPercent(_edit) * 100).ToString("0.######"))%)</strong></td>
                                                                <td class="text-end"><strong>@VatValue(_edit)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Taxes.TotalTaxes"]</strong></td>
                                                                <td class="text-end"><strong>@TotalTaxesValue(_edit)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Taxes.PriceAfterTaxes"]</strong></td>
                                                                <td class="text-end"><strong>@PriceAfterTaxes(_edit)</strong></td>
                                                                <td></td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-muted small mt-2">@L["Products.Taxes.EmptyHint"]</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="row g-2 mb-2">
                                        <div class="col-md-6">
                                            <label class="form-label">@L["Products.Field.Cost"]</label>
                                            <InputNumber class="form-control" @bind-Value="_edit.Cost" />
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check mt-4">
                                                <InputCheckbox class="form-check-input" @bind-Value="_edit.IsActive" />
                                                <label class="form-check-label">@L["Common.Active"]</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card mb-3">
                                        <div class="card-header">
                                            <h5 class="m-0">@L["Products.Section.Barcodes"]</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="row g-2 align-items-end">
                                                <div class="col-8">
                                                    <label class="form-label">@L["Products.PrimaryBarcode"]</label>
                                                    <InputText class="form-control" @bind-Value="_barcode" />
                                                </div>
                                                <div class="col-4 text-end">
                                                    <button class="btn btn-outline-primary w-100" type="button" @onclick="AddBarcode" disabled="@_busy">@L["Common.Add"]</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card mb-3">
                                        <div class="card-header">
                                            <h5 class="m-0">@L["Products.Section.Units"]</h5>
                                        </div>
                                        <div class="card-body">
                                            @if (_unitsBusy)
                                            {
                                                <div class="text-muted">Loading...</div>
                                            }
                                            else
                                            {
                                                @if (!string.IsNullOrWhiteSpace(_unitError))
                                                {
                                                    <div class="alert alert-danger">@_unitError</div>
                                                }

                                                @if (_units.Count == 0)
                                                {
                                                    <div class="text-muted mb-2">No units.</div>
                                                }
                                                else
                                                {
                                                    <div class="table-responsive mb-2">
                                                        <table class="table table-sm table-striped align-middle">
                                                            <thead>
                                                                <tr>
                                                                    <th>@L["Common.Name"]</th>
                                                                    <th class="text-end">@L["Products.Units.Factor"]</th>
                                                                    <th>@L["Products.Units.Default"]</th>
                                                                    <th>@L["Common.Active"]</th>
                                                                    <th></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var u in _units)
                                                                {
                                                                    <tr>
                                                                        <td>@u.Name</td>
                                                                        <td class="text-end">@u.Factor</td>
                                                                        <td>@(u.IsDefault ? L["Common.Yes"] : L["Common.No"])</td>
                                                                        <td>@(u.IsActive ? L["Common.Yes"] : L["Common.No"])</td>
                                                                        <td class="text-end">
                                                                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => SelectUnitForEdit(u)" disabled="@_busy">@L["Common.Edit"]</button>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }

                                                <div class="fw-bold mb-2">@(_unitEdit is null ? L["Products.Units.AddUnit"] : L["Products.Units.EditUnit"])</div>
                                                <div class="row g-2">
                                                    <div class="col-12 col-md-6">
                                                        <label class="form-label">@L["Common.Name"]</label>
                                                        <InputText class="form-control" @bind-Value="_unitForm.Name" />
                                                    </div>
                                                    <div class="col-12 col-md-6">
                                                        <label class="form-label">@L["Products.Units.Factor"]</label>
                                                        <input class="form-control" type="number" step="0.001" @bind-value="_unitForm.Factor" @bind-value:event="oninput" />
                                                    </div>
                                                    <div class="col-6">
                                                        <div class="form-check mt-4">
                                                            <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsDefault" />
                                                            <label class="form-check-label">@L["Products.Units.Default"]</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-6">
                                                        <div class="form-check mt-4">
                                                            <InputCheckbox class="form-check-input" @bind-Value="_unitForm.IsActive" />
                                                            <label class="form-check-label">@L["Common.Active"]</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="d-flex gap-2 mt-2">
                                                    <button class="btn btn-outline-primary" type="button" @onclick="SaveUnit" disabled="@_busy">@L["Common.Save"]</button>
                                                    @if (_unitEdit is not null)
                                                    {
                                                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearUnitEdit" disabled="@_busy">@L["Common.Cancel"]</button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@_busy">@L["Common.Cancel"]</button>
                                    <button type="submit" class="btn btn-primary" disabled="@_busy">@L["Common.Save"]</button>
                                </div>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private enum ProductModalMode
    {
        None = 0,
        Create = 1,
        Edit = 2
    }

    private bool _busy;
    private string? _error;
    private string _search = "";
    private List<ProductItem> _products = [];
    private List<CategoryItem> _categories = [];
    private List<TaxRateItem> _taxRates = [];
    private List<TaxTypeItem> _taxTypes = [];

    private Dictionary<Guid, string> _categoryNameById = [];
    private Dictionary<Guid, string> _taxRateNameById = [];
    private Dictionary<Guid, string> _taxTypeNameById = [];
    private ProductModalMode _modalMode = ProductModalMode.None;
    private CreateProductModel _create = new() { IsActive = true };
    private EditProductModel? _edit;
    private string _barcode = "";
    private bool _initialLoadDone;

    private bool _unitsBusy;
    private string? _unitError;
    private List<ProductUnitItem> _units = [];
    private ProductUnitItem? _unitEdit;
    private UnitFormModel _unitForm = new();

    private bool _productTaxesBusy;
    private string? _productTaxesError;
    private bool _bodyModalOpen;

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    private void ResetCreateModel()
    {
        _create = new CreateProductModel { IsActive = true };
        _productTaxesBusy = false;
        _productTaxesError = null;

        if (_create.CategoryId is null && _categories.Count == 1)
        {
            _create.CategoryId = _categories[0].Id;
        }

        if (_create.TaxRateId is null && _taxRates.Count == 1)
        {
            _create.TaxRateId = _taxRates[0].Id;
        }

        if (_create.SalesTaxTypeId is null && _taxTypes.Count == 1)
        {
            _create.SalesTaxTypeId = _taxTypes[0].Id;
        }
    }

    private void OpenCreateModal()
    {
        _error = null;
        _edit = null;
        _barcode = "";
        _units = [];
        _unitsBusy = false;
        _unitError = null;
        _productTaxesBusy = false;
        _productTaxesError = null;
        ClearUnitEdit();

        ResetCreateModel();
        _modalMode = ProductModalMode.Create;
    }

    private async Task OpenEditModal(ProductItem p)
    {
        _error = null;
        _modalMode = ProductModalMode.Edit;
        await SelectForEdit(p);
    }

    private void CloseModal()
    {
        _modalMode = ProductModalMode.None;
        _barcode = "";
        _units = [];
        _unitsBusy = false;
        _unitError = null;
        _productTaxesBusy = false;
        _productTaxesError = null;
        ClearUnitEdit();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await EnsureBodyModalStateAsync();

        if (!firstRender || _initialLoadDone)
        {
            return;
        }

        _initialLoadDone = true;
        await Session.EnsureLoadedAsync();
        if (Session.IsLoggedIn)
        {
            await Load();
        }

        StateHasChanged();
    }

    private async Task EnsureBodyModalStateAsync()
    {
        var open = _modalMode != ProductModalMode.None;
        if (open == _bodyModalOpen)
        {
            return;
        }

        _bodyModalOpen = open;
        try
        {
            await JS.InvokeVoidAsync("miniErpUi.setBodyModalOpen", open);
        }
        catch
        {
            // ignore JS interop failures
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!_bodyModalOpen)
        {
            return;
        }

        _bodyModalOpen = false;
        try
        {
            await JS.InvokeVoidAsync("miniErpUi.setBodyModalOpen", false);
        }
