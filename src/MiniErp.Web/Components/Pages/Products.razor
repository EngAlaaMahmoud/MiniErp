    private async Task LoadLookups()
    {
        _categories = await Api.GetAsync<List<CategoryItem>>("catalog/categories");
        _taxRates = await Api.GetAsync<List<TaxRateItem>>("taxes/rates");
        _taxTypes = await Api.GetAsync<List<TaxTypeItem>>("taxes/types");

        _categoryNameById = _categories.ToDictionary(x => x.Id, x => x.Name);
        _taxRateNameById = _taxRates.ToDictionary(x => x.Id, x => x.Name);
        _taxTypeNameById = _taxTypes.ToDictionary(x => x.Id, x => $"{x.MainCode}/{x.SubCode}");

        if (_modalMode == ProductModalMode.None)
        {
            ResetCreateModel();
        }
    }

    private async Task Load()
    {
        _error = null;
        try
        {
            await LoadLookups();
            var q = string.IsNullOrWhiteSpace(_search) ? "" : $"?search={Uri.EscapeDataString(_search)}";
            _products = await Api.GetAsync<List<ProductItem>>($"catalog/products{q}");
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Create()
    {
        _busy = true;
        _error = null;
        try
        {
            SyncPrimarySalesTaxType(_create);

            if (_create.TaxRateId is null || _create.TaxRateId.Value == Guid.Empty)
            {
                _error = L["Products.Error.VatRateRequired"].Value;
                return;
            }

            var response = await Api.PostAsync("catalog/products", new
            {
                name = _create.Name,
                sku = string.IsNullOrWhiteSpace(_create.Sku) ? null : _create.Sku,
                brandName = string.IsNullOrWhiteSpace(_create.BrandName) ? null : _create.BrandName,
                description = string.IsNullOrWhiteSpace(_create.Description) ? null : _create.Description,
                price = _create.Price,
                defaultDiscount = _create.DefaultDiscount,
                defaultUnitName = string.IsNullOrWhiteSpace(_create.DefaultUnitName) ? null : _create.DefaultUnitName,
                cost = _create.Cost,
                categoryId = _create.CategoryId,
                taxRateId = _create.TaxRateId,
                salesTaxTypeId = _create.SalesTaxTypeId,
                reorderLevel = _create.ReorderLevel,
                isActive = _create.IsActive
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<ProductItem>();
            if (created is not null && !string.IsNullOrWhiteSpace(_create.PrimaryBarcode))
            {
                var barcodeResponse = await Api.PostAsync($"catalog/products/{created.Id}/barcodes", new { code = _create.PrimaryBarcode.Trim() });
                if (!barcodeResponse.IsSuccessStatusCode)
                {
                    _error = await barcodeResponse.Content.ReadAsStringAsync();
                }
            }

            if (created is not null && _create.Taxes.Count > 0)
            {
                await SaveProductTaxes(created.Id, _create.Taxes);
                if (!string.IsNullOrWhiteSpace(_productTaxesError))
                {
                    _error = _productTaxesError;
                }
            }

            ResetCreateModel();
            CloseModal();
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

