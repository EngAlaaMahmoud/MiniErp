                                                            </tr>
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>@L["Products.Taxes.PriceAfterTaxes"]</strong></td>
                                                                <td class="text-end"><strong>@PriceAfterTaxes(_create)</strong></td>
