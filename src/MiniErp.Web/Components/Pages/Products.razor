                                                <div class="table-responsive mt-3">
                                                    <table class="table table-bordered table-sm align-middle">
                                                        <thead>
                                                            <tr>
                                                                <th>@L["Taxes.Col.MainCode"]</th>
                                                                <th>@L["Taxes.Col.SubCode"]</th>
                                                                <th>@L["Taxes.Col.TaxType"]</th>
                                                                <th class="text-end">@L["Taxes.Col.Percent"]</th>
                                                                <th class="text-end">@L["Products.Col.AdditionalTaxes"]</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @for (var i = 0; i < _create.Taxes.Count; i++)
                                                            {
                                                                var row = _create.Taxes[i];
                                                                var taxType = LookupTaxType(row);
                                                                <tr>
                                                                    <td style="min-width:140px">
                                                                        <select class="form-select form-select-sm" value="@row.MainCode" @onchange="e => OnTaxMainCodeChanged(_create, row, e)">
                                                                            <option value="">-</option>
                                                                            @foreach (var main in GetUniqueMainCodes())
                                                                            {
                                                                                <option value="@main">@main</option>
                                                                            }
                                                                        </select>
                                                                    </td>
                                                                    <td style="min-width:220px">
                                                                        <select class="form-select form-select-sm" value="@row.SubCode" disabled="@string.IsNullOrWhiteSpace(row.MainCode)" @onchange="e => OnTaxSubCodeChanged(_create, row, e)">
                                                                            <option value="">-</option>
                                                                            @foreach (var sub in GetSubCodesByMainCode(row.MainCode))
                                                                            {
                                                                                <option value="@sub.SubCode">@sub.SubCode - @sub.Description</option>
                                                                            }
                                                                        </select>
                                                                    </td>
                                                                    <td>
                                                                        <input class="form-control form-control-sm" value="@(taxType?.TaxType ?? "-")" readonly />
                                                                    </td>
                                                                    <td class="text-end" style="min-width:110px">
                                                                        <input class="form-control form-control-sm text-end" value="@(((taxType?.Percent ?? 0m) * 100).ToString(PercentFormat))%" readonly />
