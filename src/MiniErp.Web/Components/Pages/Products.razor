                                                                        <input class="form-control form-control-sm text-end" value="@TaxValue(_edit, row)" readonly />
                                                                    </td>
                                                                    <td class="text-end" style="width:1%">
                                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveTaxRow(_edit, i)" disabled="@_busy">×</button>
