@page "/purchases"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiSession Session
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@using Microsoft.JSInterop

<PageTitle>@L["Nav.Purchases"]</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 m-0">@L["Nav.Purchases"]</h1>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="Reload" disabled="@_busy">@L["Common.Refresh"]</button>
            <a class="btn btn-outline-secondary" href="/">@L["Common.Back"]</a>
        </div>
    </div>

    @if (!_ready)
    {
        <div class="text-muted">@L["Common.Loading"]</div>
    }
    else if (!Session.IsLoggedIn)
    {
        <div class="alert alert-warning">@L["Auth.Required"]</div>
        <a class="btn btn-primary" href="/login">@L["Auth.Login"]</a>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="alert alert-success d-print-none">
                <div class="d-flex justify-content-between align-items-center">
                    <div>@_success</div>
                    <button class="btn btn-sm btn-outline-dark" @onclick="PrintLast" disabled="@_busy">@L["Common.Print"]</button>
                </div>
            </div>
        }

        <div class="row g-3 d-print-none">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Purchases.ListTitle"]</div>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>@L["Common.Number"]</th>
                                        <th>@L["Common.Date"]</th>
                                        <th>@L["Common.Party"]</th>
                                        <th class="text-end">@L["Common.Tax"]</th>
                                        <th class="text-end">@L["Common.Total"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _purchases)
                                    {
                                        <tr>
                                            <td><code>@(string.IsNullOrWhiteSpace(p.ExternalNumber) ? p.Number : p.ExternalNumber)</code></td>
                                            <td class="text-muted">@p.At.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@(string.IsNullOrWhiteSpace(p.SupplierName) ? "-" : p.SupplierName)</td>
                                            <td class="text-end">@p.TaxTotal</td>
                                            <td class="text-end">@p.Total</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <div class="fw-bold mb-2">@L["Purchases.CreateTitle"]</div>

                        <div class="row g-2 mb-2">
                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["Purchases.ExternalNumber"]</label>
                                <input class="form-control" @bind="_externalNumber" disabled="@_busy" />
                                <div class="small text-muted">@L["Purchases.ExternalNumberHint"]</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">@L["Common.Date"]</label>
                                <InputDate class="form-control" @bind-Value="_invoiceDate" disabled="@_busy" />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">@L["Purchases.SupplierOptional"]</label>
                            <select class="form-select" @bind="_supplierId" disabled="@_busy">
                                <option value="">-</option>
                                @foreach (var s in _suppliers.Where(x => x.IsActive).OrderBy(x => x.Name))
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </select>
                        </div>

                        @if (string.IsNullOrWhiteSpace(_supplierId))
                        {
                            <div class="mb-2">
                                <input class="form-control" placeholder="@L["Purchases.SupplierNameOptional"]" @bind="_supplierName" disabled="@_busy" />
                            </div>
                            <div class="mb-2">
                                <input class="form-control" placeholder="@L["Purchases.SupplierTaxNoOptional"]" @bind="_supplierTaxRegistrationNo" disabled="@_busy" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">@L["Purchases.Address"]</label>
                                <div class="row g-2">
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.Country"]" @bind="_supplierCountry" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.Governorate"]" @bind="_supplierGovernorate" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.City"]" @bind="_supplierCity" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.BuildingNo"]" @bind="_supplierBuildingNo" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.Floor"]" @bind="_supplierFloor" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.Apartment"]" @bind="_supplierApartment" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <input class="form-control" placeholder="@L["Customers.StreetName"]" @bind="_supplierStreetName" disabled="@_busy" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <input class="form-control" placeholder="@L["Customers.PostalCodeOptional"]" @bind="_supplierPostalCode" disabled="@_busy" />
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            var s = SelectedSupplier;
                            if (s is not null)
                            {
                                <div class="small text-muted mb-1">@L["Purchases.SupplierTaxNoLabel"]: @(string.IsNullOrWhiteSpace(s.TaxRegistrationNo) ? "-" : s.TaxRegistrationNo)</div>
                                <div class="small text-muted mb-3">@L["Purchases.Address"]: @BuildAddress(s.Country, s.Governorate, s.City, s.BuildingNo, s.Floor, s.Apartment, s.StreetName, s.PostalCode, s.Address)</div>
                            }
                        }

                        <div class="row g-2 mb-2">
                            <div class="col-12">
                                <label class="form-label">@L["Common.Product"]</label>
                                <select class="form-select" value="@_lineProductId" @onchange="OnLineProductChanged" disabled="@_busy">
                                    <option value="">@L["Common.Select"]</option>
                                    @foreach (var p in _products.Where(x => x.IsActive).OrderBy(x => x.Name))
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                                @if (SelectedProduct is not null)
                                {
                                    <div class="small text-muted mt-1">
                                        @L["Products.InternalCode"]: @(string.IsNullOrWhiteSpace(SelectedProduct.Sku) ? "-" : SelectedProduct.Sku)
                                        • @L["Products.PrimaryBarcode"]: @(string.IsNullOrWhiteSpace(SelectedProduct.PrimaryBarcode) ? "-" : SelectedProduct.PrimaryBarcode)
                                    </div>
                                }
                            </div>
                            <div class="col-12">
                                <label class="form-label">@L["Common.Unit"]</label>
                                <select class="form-select" @bind="_lineProductUnitId" disabled="@(_busy || string.IsNullOrWhiteSpace(_lineProductId) || _lineUnits.Count == 0)">
                                    <option value="">-</option>
                                    @foreach (var u in _lineUnits.Where(x => x.IsActive))
                                    {
                                        <option value="@u.Id">@u.Name (x@u.Factor)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label">@L["Common.Quantity"]</label>
                                <input class="form-control text-end" type="number" step="0.001" @bind-value="_lineQty" @bind-value:event="oninput" disabled="@_busy" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">@L["Purchases.UnitCost"]</label>
                                <input class="form-control text-end" type="number" step="0.001" @bind-value="_lineUnitCost" @bind-value:event="oninput" disabled="@_busy" />
                            </div>
                        </div>

                        <button class="btn btn-outline-secondary w-100 mb-3" @onclick="AddLine" disabled="@_busy">@L["Common.AddLine"]</button>

                        @if (_lines.Count != 0)
                        {
                            <div class="table-responsive mb-2">
                                <table class="table table-sm table-striped align-middle">
                                    <thead>
                                        <tr>
                                            <th>@L["Common.Product"]</th>
                                            <th>@L["Common.Unit"]</th>
                                            <th class="text-end">@L["Common.Quantity"]</th>
                                            <th class="text-end">@L["Purchases.UnitCost"]</th>
                                            <th class="text-end">@L["Common.Total"]</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < _lines.Count; i++)
                                        {
                                            var l = _lines[i];
                                            <tr>
                                                <td>@l.ProductName</td>
                                                <td class="text-muted">@((string.IsNullOrWhiteSpace(l.UnitName) ? "-" : l.UnitName))</td>
                                                <td class="text-end">@l.Qty</td>
                                                <td class="text-end">@l.UnitCost</td>
                                                <td class="text-end">@l.LineTotal</td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(i)" disabled="@_busy">×</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <div class="mb-2">
                            <label class="form-label">@L["Purchases.CashPaid"]</label>
                            <input class="form-control text-end" type="number" step="0.001" @bind-value="_cashPaid" @bind-value:event="oninput" disabled="@_busy" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">@L["Common.NoteOptional"]</label>
                            <input class="form-control" @bind="_note" disabled="@_busy" />
                        </div>

                        <div class="card bg-body-tertiary border-0 mb-2">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between"><span>@L["Common.Total"]</span><span class="fw-bold">@Total</span></div>
                                <div class="d-flex justify-content-between"><span>@L["Common.Tax"] (VAT)</span><span>@VatTotal</span></div>
                                <div class="d-flex justify-content-between"><span>@L["Purchases.TotalBeforeVat"]</span><span class="text-muted">@TotalBeforeVat</span></div>
                            </div>
                        </div>

                        <button class="btn btn-primary w-100" @onclick="Save" disabled="@(_busy || _lines.Count == 0)">@L["Common.Save"]</button>
                    </div>
                </div>
            </div>
        </div>

        @if (_lastReceipt is not null)
        {
            <div class="d-none d-print-block">
                <h2 class="h4">@L["Purchases.PrintTitle"]</h2>
                <div class="small text-muted">@L["Common.Number"]: @_lastReceipt.ExternalNumber</div>
                <div class="small text-muted">@L["Common.Date"]: @_lastReceipt.At.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                <div class="small text-muted">@L["Common.Party"]: @_lastReceipt.SupplierName</div>
                <div class="small text-muted">@L["Purchases.SupplierTaxNoLabel"]: @_lastReceipt.SupplierTaxRegistrationNo</div>
                <div class="small text-muted mb-2">@L["Purchases.Address"]: @_lastReceipt.SupplierAddress</div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>@L["Common.Product"]</th>
                            <th>@L["Common.Unit"]</th>
                            <th class="text-end">@L["Common.Quantity"]</th>
                            <th class="text-end">@L["Purchases.UnitCost"]</th>
                            <th class="text-end">@L["Common.Total"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _lastReceipt.Lines)
                        {
                            <tr>
                                <td>@l.ProductName</td>
                                <td>@(string.IsNullOrWhiteSpace(l.UnitName) ? "-" : l.UnitName)</td>
                                <td class="text-end">@l.Qty</td>
                                <td class="text-end">@l.UnitCost</td>
                                <td class="text-end">@l.LineTotal</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex justify-content-between"><span>@L["Common.Total"]</span><span class="fw-bold">@_lastReceipt.Total</span></div>
                <div class="d-flex justify-content-between"><span>@L["Common.Tax"] (VAT)</span><span>@_lastReceipt.TaxTotal</span></div>
                <div class="d-flex justify-content-between"><span>@L["Purchases.TotalBeforeVat"]</span><span class="text-muted">@(_lastReceipt.Total - _lastReceipt.TaxTotal)</span></div>
                <div class="d-flex justify-content-between"><span>@L["Purchases.CashPaid"]</span><span>@_lastReceipt.CashPaid</span></div>
            </div>
        }
    }
</div>

@code {
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _success;

    private List<ProductItem> _products = [];
    private List<SupplierOption> _suppliers = [];
    private List<PurchaseItem> _purchases = [];

    private string _externalNumber = "";
    private DateTime _invoiceDate = DateTime.Today;

    private string _supplierId = "";
    private string? _supplierName;
    private string _supplierTaxRegistrationNo = "";
    private string _supplierCountry = "مصر";
    private string _supplierGovernorate = "";
    private string _supplierCity = "";
    private string _supplierBuildingNo = "";
    private string _supplierFloor = "";
    private string _supplierApartment = "";
    private string _supplierStreetName = "";
    private string _supplierPostalCode = "";

    private string _lineProductId = "";
    private string _lineProductUnitId = "";
    private List<UnitOption> _lineUnits = [];
    private decimal _lineQty = 1;
    private decimal _lineUnitCost;
    private decimal _cashPaid;
    private string? _note;

    private List<PurchaseLineUi> _lines = [];
    private PurchaseReceipt? _lastReceipt;
    private bool _initialLoadDone;

    private decimal Total => _lines.Sum(x => x.LineTotal);
    private decimal VatTotal => _lastReceipt?.TaxTotal ?? 0m;
    private decimal TotalBeforeVat => Total - (_lastReceipt?.TaxTotal ?? 0m);

    private SupplierOption? SelectedSupplier =>
        Guid.TryParse(_supplierId, out var id) ? _suppliers.SingleOrDefault(x => x.Id == id) : null;

    private ProductItem? SelectedProduct =>
        Guid.TryParse(_lineProductId, out var id) ? _products.SingleOrDefault(x => x.Id == id) : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone)
        {
            return;
        }

        _initialLoadDone = true;
        await Session.EnsureLoadedAsync();
        _ready = true;
        StateHasChanged();

        if (Session.IsLoggedIn)
        {
            await Reload();
        }
    }

    private async Task Reload()
    {
        _busy = true;
        _error = null;
        try
        {
            _products = await Api.GetAsync<List<ProductItem>>("catalog/products");
            _suppliers = await Api.GetAsync<List<SupplierOption>>("suppliers");
            _purchases = await Api.GetAsync<List<PurchaseItem>>($"purchases?branchId={Session.BranchId}");
        }
        catch (ApiUnauthorizedException ex)
        {
            if (ex.WasAuthenticated)
            {
                await Session.ClearAsync();
            }
            RedirectToLogin();
        }
        catch (ApiHttpException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Body) ? ex.Message : ex.Body;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnLineProductChanged(ChangeEventArgs e)
    {
        _lineProductId = e.Value?.ToString() ?? "";
        _lineProductUnitId = "";
        _lineUnits = [];

        if (!Guid.TryParse(_lineProductId, out var productId) || productId == Guid.Empty)
        {
            return;
        }

        _busy = true;
        try
        {
            _lineUnits = await Api.GetAsync<List<UnitOption>>($"catalog/products/{productId}/units");
            var def = _lineUnits.FirstOrDefault(x => x.IsDefault && x.IsActive) ?? _lineUnits.FirstOrDefault(x => x.IsActive);
            _lineProductUnitId = def?.Id.ToString() ?? "";
        }
        catch
        {
            _lineUnits = [];
            _lineProductUnitId = "";
        }
        finally
        {
            _busy = false;
        }
    }

    private void AddLine()
    {
        _error = null;

        if (!Guid.TryParse(_lineProductId, out var productId) || productId == Guid.Empty)
        {
            _error = "اختر منتج";
            return;
        }

        Guid? unitId = null;
        string? unitName = null;
        if (!string.IsNullOrWhiteSpace(_lineProductUnitId) &&
            Guid.TryParse(_lineProductUnitId, out var parsedUnitId) &&
            parsedUnitId != Guid.Empty)
        {
            unitId = parsedUnitId;
            unitName = _lineUnits.SingleOrDefault(x => x.Id == parsedUnitId)?.Name;
        }

        if (_lineQty <= 0)
        {
            _error = "Qty لازم يكون أكبر من 0";
            return;
        }

        if (_lineUnitCost < 0)
        {
            _error = "UnitCost غير صحيح";
            return;
        }

        var product = _products.Single(x => x.Id == productId);
        _lines.Add(new PurchaseLineUi(productId, product.Name, unitId, unitName, _lineQty, _lineUnitCost));

        _lineProductId = "";
        _lineProductUnitId = "";
        _lineUnits = [];
        _lineQty = 1;
        _lineUnitCost = 0;
        _cashPaid = Total;
    }

    private void RemoveLine(int index)
    {
        _lines.RemoveAt(index);
        _cashPaid = Total;
    }

    private async Task Save()
    {
        if (_lines.Count == 0)
        {
            return;
        }

        Guid? supplierId = null;
        string? supplierName = null;
        string? supplierTaxNo = null;
        string? supplierAddress = null;
        if (!string.IsNullOrWhiteSpace(_supplierId) && Guid.TryParse(_supplierId, out var parsedSupplierId) && parsedSupplierId != Guid.Empty)
        {
            supplierId = parsedSupplierId;
            var s = _suppliers.SingleOrDefault(x => x.Id == parsedSupplierId);
            supplierName = s?.Name;
        }
        else if (!string.IsNullOrWhiteSpace(_supplierName))
        {
            supplierName = _supplierName.Trim();
            supplierTaxNo = NullIfEmpty(_supplierTaxRegistrationNo);
            supplierAddress = BuildAddress(_supplierCountry, _supplierGovernorate, _supplierCity, _supplierBuildingNo, _supplierFloor, _supplierApartment, _supplierStreetName, _supplierPostalCode, null);
        }

        _busy = true;
        _error = null;
        _success = null;
        try
        {
            var response = await Api.PostAsync("purchases", new
            {
                branchId = Session.BranchId,
                at = new DateTimeOffset(_invoiceDate.Date, TimeSpan.Zero),
                externalNumber = NullIfEmpty(_externalNumber),
                supplierId,
                supplierName,
                supplierTaxRegistrationNo = supplierTaxNo,
                supplierAddress,
                items = _lines.Select(x => new { productId = x.ProductId, productUnitId = x.ProductUnitId, qty = x.Qty, unitCost = x.UnitCost }).ToArray(),
                cashPaid = _cashPaid,
                note = string.IsNullOrWhiteSpace(_note) ? null : _note
            });

            if (!response.IsSuccessStatusCode)
            {
                _error = await response.Content.ReadAsStringAsync();
                return;
            }

            var body = await response.Content.ReadFromJsonAsync<CreatePurchaseResponse>(new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
            _success = $"{L["Purchases.Saved"].Value}: {body?.PurchaseNo}";

            var selectedSupplier = supplierId is null ? null : _suppliers.SingleOrDefault(x => x.Id == supplierId.Value);
            var printSupplierTax = supplierId is null ? supplierTaxNo : selectedSupplier?.TaxRegistrationNo;
            var printSupplierAddress = supplierId is null
                ? supplierAddress
                : BuildAddress(selectedSupplier?.Country, selectedSupplier?.Governorate, selectedSupplier?.City, selectedSupplier?.BuildingNo, selectedSupplier?.Floor, selectedSupplier?.Apartment, selectedSupplier?.StreetName, selectedSupplier?.PostalCode, selectedSupplier?.Address);

            _lastReceipt = new PurchaseReceipt(
                body?.PurchaseNo ?? "",
                NullIfEmpty(_externalNumber) ?? (body?.PurchaseNo ?? ""),
                DateTimeOffset.Now,
                supplierName,
                printSupplierTax,
                printSupplierAddress,
                _lines.Select(x => new PurchaseReceiptLine(x.ProductName, x.UnitName, x.Qty, x.UnitCost)).ToList(),
                Total,
                body?.TaxTotal ?? 0m,
                _cashPaid,
                string.IsNullOrWhiteSpace(_note) ? null : _note);

            _externalNumber = "";
            _supplierId = "";
            _supplierName = null;
            _supplierTaxRegistrationNo = "";
            _supplierCountry = "مصر";
            _supplierGovernorate = "";
            _supplierCity = "";
            _supplierBuildingNo = "";
            _supplierFloor = "";
            _supplierApartment = "";
            _supplierStreetName = "";
            _supplierPostalCode = "";
            _note = null;
            _lines.Clear();
            _cashPaid = 0;
            await Reload();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PrintLast()
    {
        if (_lastReceipt is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("window.print");
    }

    private void RedirectToLogin()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/login" : $"/login?return=/{Uri.EscapeDataString(relative)}";
        Nav.NavigateTo(target);
    }

    private static string? NullIfEmpty(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string? BuildAddress(
        string? country,
        string? governorate,
        string? city,
        string? buildingNo,
        string? floor,
        string? apartment,
        string? streetName,
        string? postalCode,
        string? freeForm)
    {
        var parts = new List<string>(10);
        if (!string.IsNullOrWhiteSpace(country)) parts.Add(country.Trim());
        if (!string.IsNullOrWhiteSpace(governorate)) parts.Add(governorate.Trim());
        if (!string.IsNullOrWhiteSpace(city)) parts.Add(city.Trim());
        if (!string.IsNullOrWhiteSpace(buildingNo)) parts.Add(buildingNo.Trim());
        if (!string.IsNullOrWhiteSpace(floor)) parts.Add(floor.Trim());
        if (!string.IsNullOrWhiteSpace(apartment)) parts.Add(apartment.Trim());
        if (!string.IsNullOrWhiteSpace(streetName)) parts.Add(streetName.Trim());
        if (!string.IsNullOrWhiteSpace(postalCode)) parts.Add(postalCode.Trim());
        if (!string.IsNullOrWhiteSpace(freeForm)) parts.Add(freeForm.Trim());
        return parts.Count == 0 ? null : string.Join(" - ", parts);
    }

    private sealed class ProductItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public bool IsActive { get; set; }
        public string? PrimaryBarcode { get; set; }
    }

    private sealed class SupplierOption
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public bool IsActive { get; set; }
        public string? TaxRegistrationNo { get; set; }
        public string? Country { get; set; }
        public string? Governorate { get; set; }
        public string? City { get; set; }
        public string? BuildingNo { get; set; }
        public string? Floor { get; set; }
        public string? Apartment { get; set; }
        public string? StreetName { get; set; }
        public string? PostalCode { get; set; }
        public string? Address { get; set; }
    }

    private sealed class PurchaseItem
    {
        public Guid Id { get; set; }
        public string Number { get; set; } = "";
        public string? ExternalNumber { get; set; }
        public Guid BranchId { get; set; }
